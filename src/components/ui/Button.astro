---
interface Props {
    variant?: "primary" | "secondary" | "accent" | "outline";
    size?: "sm" | "md" | "lg";
    href?: string;
    type?: "button" | "submit" | "reset";
    class?: string;
    disabled?: boolean;
    icon?: boolean;
}

const {
    variant = "primary",
    size = "md",
    href,
    type = "button",
    class: className,
    disabled = false,
    icon = true,
} = Astro.props;

const baseStyles =
    "inline-block font-heading font-bold uppercase tracking-[0.2em] transition-all duration-300";

const variants = {
    primary:
        "bg-[var(--color-primary)] text-white hover:bg-[#1f2d4d] hover:shadow-2xl hover:scale-105",
    secondary:
        "bg-[var(--color-secondary)] text-white hover:bg-[#2f3844] hover:shadow-2xl hover:scale-105",
    accent: "bg-[var(--color-accent)] text-white hover:bg-[#d97706] hover:shadow-2xl hover:scale-105",
    outline:
        "border-2 border-[var(--color-primary)] text-[var(--color-primary)] bg-transparent hover:bg-[var(--color-primary)] hover:text-white hover:shadow-2xl hover:scale-105",
};

const sizes = {
    sm: "px-6 py-3 text-base",
    md: "px-10 py-4 text-lg",
    lg: "px-14 py-5 text-xl",
};

const disabledStyles = disabled
    ? "opacity-50 cursor-not-allowed"
    : "cursor-pointer";

const buttonClass = `${baseStyles} ${variants[variant]} ${sizes[size]} ${disabledStyles} ${className || ""}`;

const Tag = href ? "a" : "button";
---

<Tag
    href={href}
    class={buttonClass}
    {...href ? {} : { type }}
    {...disabled ? { disabled: true } : {}}
>
    <span class="inline-flex items-center gap-3">
        <slot />
        {
            icon && (
                <svg
                    class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    stroke-width="3"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M13 7l5 5m0 0l-5 5m5-5H6"
                    />
                </svg>
            )
        }
    </span>
</Tag>

<style>
    a,
    button {
        border-radius: 0 !important;
    }

    button:disabled {
        pointer-events: none;
    }

    a:hover svg,
    button:hover:not(:disabled) svg {
        transform: translateX(4px);
    }
</style>
