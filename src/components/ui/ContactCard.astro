---
interface Props {
    icon: string;
    title: string;
    subtitle: string;
    link: string;
    linkText: string;
}

const { icon, title, subtitle, link, linkText } = Astro.props;
---

<div
    class="bg-white p-8 shadow-lg hover:shadow-2xl transition-all duration-300 group"
>
    <div
        class="w-16 h-16 bg-accent/10 flex items-center justify-center mb-6 group-hover:bg-accent transition-colors duration-300"
    >
        <svg
            class="w-8 h-8 text-accent group-hover:text-white transition-colors duration-300"
            fill="currentColor"
            viewBox="0 0 20 20"
        >
            <Fragment set:html={icon} />
        </svg>
    </div>
    <h3 class="font-heading font-bold text-xl md:text-2xl text-[#1e3a5f] mb-4">
        {title}
    </h3>
    <p class="text-base text-gray-600 mb-4">
        {subtitle}
    </p>
    <a
        href={link}
        class="text-lg font-heading font-bold text-accent hover:text-primary transition-colors"
    >
        {linkText}
    </a>
</div>
