---
// Services component - showcases what the company offers
---

<section class="py-18 pb-2 px-6 bg-(--color-background)">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="heading-h2 font-heading font-bold text-[#1e3a5f] mb-6">
        Digital Solutions for Contractors
      </h2>
      <p
        class="text-subtitle text-secondary max-w-5xl mx-auto leading-relaxed font-body"
      >
        We specialize in creating high-converting websites and digital marketing
        solutions specifically designed for contractors, home service
        professionals, and trade businesses.
      </p>
    </div>

    <!-- Main Services Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
      <!-- Website Design & Development -->
      <div
        class="group bg-gray-50 p-10 hover:-translate-y-1 transition-all duration-300 border border-gray-200"
      >
        <div class="flex items-start gap-6">
          <div
            class="w-16 h-16 bg-accent flex items-center justify-center shrink-0"
          >
            <svg
              class="w-8 h-8 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <div class="flex-1">
            <p
              class="text-2xl font-heading font-bold text-[#1e3a5f] mb-4 group-hover:text-accent transition-colors duration-300"
            >
              Website Templates
            </p>
            <p
              class="text-secondary mb-6 leading-relaxed font-body text-[18px]"
            >
              Industry-specific website templates built for HVAC, plumbing,
              electrical, roofing, and landscaping businesses. Each template is
              conversion-optimized and fully mobile-first.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <svg
                  class="w-5 h-5 text-accent shrink-0"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"></path>
                </svg>
                <span class="text-secondary font-body text-[18px]"
                  >Mobile-responsive design</span
                >
              </li>
              <li class="flex items-center gap-3">
                <svg
                  class="w-5 h-5 text-accent shrink-0"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"></path>
                </svg>
                <span class="text-secondary font-body text-[18px]"
                  >Lead generation focused</span
                >
              </li>
              <li class="flex items-center gap-3">
                <svg
                  class="w-5 h-5 text-accent shrink-0"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                    clip-rule="evenodd"></path>
                </svg>
                <span class="text-secondary font-body text-[18px]"
                  >SEO optimized structure</span
