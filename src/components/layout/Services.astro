---
// Services component - showcases what the company offers
---

<section class="py-20 px-6 bg-[var(--color-background)]">
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="heading-h2 font-heading font-bold text-primary mb-6">
        Comprehensive Digital Solutions for Contractors
      </h2>
      <p class="text-subtitle text-secondary max-w-3xl mx-auto leading-relaxed">
        We specialize in creating high-converting websites and digital marketing solutions specifically designed for contractors, home service professionals, and trade businesses.
      </p>
    </div>

    <!-- Main Services Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20">
      <!-- Website Design & Development -->
      <div class="bg-white shadow-xl p-8 hover:shadow-2xl transition-shadow duration-300">
        <div class="flex items-start gap-6">
          <div class="w-16 h-16 bg-accent flex items-center justify-center flex-shrink-0">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-heading font-bold text-primary mb-4">
              Professional Website Templates
            </h3>
            <p class="text-secondary mb-6 leading-relaxed">
              Industry-specific website templates built for HVAC, plumbing, electrical, roofing, and landscaping businesses. Each template is conversion-optimized and mobile-first.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Mobile-responsive design</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Lead generation focused</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">SEO optimized structure</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Custom Development -->
      <div class="bg-white shadow-xl p-8 hover:shadow-2xl transition-shadow duration-300">
        <div class="flex items-start gap-6">
          <div class="w-16 h-16 bg-primary flex items-center justify-center flex-shrink-0">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-heading font-bold text-primary mb-4">
              Custom Development
            </h3>
            <p class="text-secondary mb-6 leading-relaxed">
              Tailored web solutions built from scratch to meet your specific business needs. Perfect for contractors who need unique functionality or branding.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Custom booking systems</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">CRM integrations</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Payment processing</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Digital Marketing -->
      <div class="bg-white shadow-xl p-8 hover:shadow-2xl transition-shadow duration-300">
        <div class="flex items-start gap-6">
          <div class="w-16 h-16 bg-secondary flex items-center justify-center flex-shrink-0">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-heading font-bold text-primary mb-4">
              Digital Marketing Solutions
            </h3>
            <p class="text-secondary mb-6 leading-relaxed">
              Comprehensive digital marketing strategies to help contractors dominate their local markets and generate consistent leads online.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Local SEO optimization</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Google Ads management</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Social media marketing</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Support & Maintenance -->
      <div class="bg-white shadow-xl p-8 hover:shadow-2xl transition-shadow duration-300">
        <div class="flex items-start gap-6">
          <div class="w-16 h-16 bg-accent flex items-center justify-center flex-shrink-0">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M12 2.25a9.75 9.75 0 11-9.75 9.75 9.75 9.75 0 019.75-9.75z"/>
            </svg>
          </div>
          <div class="flex-1">
            <h3 class="text-2xl font-heading font-bold text-primary mb-4">
              24/7 Support & Maintenance
            </h3>
            <p class="text-secondary mb-6 leading-relaxed">
              Ongoing support and maintenance services to keep your website running smoothly, secure, and up-to-date with the latest features and security patches.
            </p>
            <ul class="space-y-3">
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Regular security updates</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Performance monitoring</span>
              </li>
              <li class="flex items-center gap-3">
                <svg class="w-5 h-5 text-accent flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <span class="text-secondary">Content updates</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>