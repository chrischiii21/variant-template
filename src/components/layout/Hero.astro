---
import Button from "../ui/Button.astro";

interface Props {
    backgroundImage?: string;
    pretitle?: string;
    title: string;
    subtitle?: string;
    ctaText?: string;
    ctaLink?: string;
}

const {
    backgroundImage = "https://33hb9xdnm4.ucarecd.net/4e5d12ee-78c2-4e28-b857-0279426529ca/photo1460925895917afdab827c52f",
    pretitle = "BUILD YOUR INDUSTRY WITH US",
    title = "INDUSTRY",
    subtitle = "Providing Reliable Factory Services",
    ctaText = "EXPLORE NOW",
    ctaLink = "/contact",
} = Astro.props;
---

<section
    class="hero-section relative w-full h-screen flex items-center justify-center overflow-hidden"
>
    <!-- Background Image (Desktop only) -->
    <div
        class="hero-bg-image absolute inset-0 hidden md:block"
        style={`background-image: url('${backgroundImage}'); background-size: cover; background-position: center;`}
    >
    </div>

    <!-- Solid Background with Texture (Mobile only) -->
    <div class="hero-bg-mobile absolute inset-0 md:hidden bg-primary"></div>

    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- Content -->
    <div class="relative z-10 w-full px-6 text-center">
        <!-- Pretitle -->
        {
            pretitle && (
                <p class="text-subtitle font-heading font-bold uppercase tracking-[0.3em] text-white mb-6 opacity-90">
                    {pretitle}
                </p>
            )
        }

        <!-- Main Title -->
        <h1
            class="heading-h1 font-heading font-bold text-white mb-4 tracking-wider"
        >
            {title}
        </h1>

        <!-- Subtitle -->
        {
            subtitle && (
                <p class="text-subtitle font-body text-white mb-12 font-light tracking-wide">
                    {subtitle}
                </p>
            )
        }

        <!-- CTA Button -->
        <Button variant="accent" size="md" href={ctaLink} icon={false}>
            {ctaText}
        </Button>
    </div>

    <!-- Decorative Elements -->
    <div
        class="absolute bottom-0 left-0 w-full h-32 bg-gradient-to-t from-black/30 to-transparent"
    >
    </div>
</section>

<style>
    /* Ensure sharp edges for button */
    a {
        border-radius: 0 !important;
    }

    /* Mobile Background Texture */
    .hero-bg-mobile {
        background-image:
            repeating-linear-gradient(
                45deg,
                transparent,
                transparent 10px,
                rgba(255, 255, 255, 0.03) 10px,
                rgba(255, 255, 255, 0.03) 20px
            ),
            repeating-linear-gradient(
                -45deg,
                transparent,
                transparent 10px,
                rgba(255, 255, 255, 0.03) 10px,
                rgba(255, 255, 255, 0.03) 20px
            );
    }

    /* Pulsing animation for play button */
    @keyframes ping {
        75%,
        100% {
            transform: scale(1.5);
            opacity: 0;
        }
    }

    .animate-ping {
        animation: ping 2s cubic-bezier(0, 0, 0.2, 1) infinite;
    }
</style>
