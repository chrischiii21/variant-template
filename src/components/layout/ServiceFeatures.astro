---
interface Feature {
    icon: string;
    title: string;
    description: string;
}

interface Props {
    tradeName: string;
    tradeDescription: string;
    features?: Feature[];
}

const { tradeName, tradeDescription, features } = Astro.props;

const defaultFeatures: Feature[] = [
    {
        icon: "badge",
        title: "Licensed & Insured",
        description: "Fully certified professionals you can trust",
    },
    {
        icon: "clock",
        title: "24/7 Emergency Service",
        description: "Available when you need us most",
    },
    {
        icon: "dollar",
        title: "Competitive Pricing",
        description: "Free estimates with transparent pricing",
    },
    {
        icon: "check",
        title: "Satisfaction Guaranteed",
        description: "We stand behind our work 100%",
    },
];

const displayFeatures = features || defaultFeatures;

const getIconPath = (icon: string) => {
    const icons: Record<string, string> = {
        badge: "M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z",
        clock: "M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z",
        dollar: "M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z",
        check: "M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z",
    };
    return icons[icon] || icons.check;
};
---

<section class="py-20 px-6 bg-white">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="heading-h2 font-heading font-bold text-primary mb-4">
                Why Choose Our {tradeName}?
            </h2>
            <p class="text-xl text-gray-600 mx-auto font-body">
                {tradeDescription}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
            {
                displayFeatures.map((feature) => (
                    <div class="text-center">
                        <div class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center">
                            <svg
                                class="w-8 h-8 text-accent"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d={getIconPath(feature.icon)}
                                    clip-rule="evenodd"
                                />
                            </svg>
                        </div>
                        <h3 class="text-xl font-heading font-bold text-primary mb-2">
                            {feature.title}
                        </h3>
                        <p class="text-base text-gray-600 font-body">
                            {feature.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
