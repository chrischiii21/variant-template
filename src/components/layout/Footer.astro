                            ></path>
                        </svg>
                        <p
                            class="text-gray-400 text-base break-words font-body"
                        >
                            {address}
                        </p>
                    </div>

                    <div class="flex items-start gap-2">
                        <svg
                            class="w-5 h-5 text-accent mt-0.5 shrink-0"
                            fill="currentColor"
                            viewBox="0 0 24 24"
