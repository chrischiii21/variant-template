---

---

<footer class="bg-[#304678] text-white py-12">
    <div class="max-w-6xl mx-auto px-6">
        <!-- Footer Grid -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
            <!-- Company Info -->
            <div>
                <h3 class="font-heading font-bold text-lg mb-4">About Us</h3>
                <p class="text-gray-300 text-sm leading-relaxed">
                    Professional services for all your construction and trade
                    needs since 1982.
                </p>
            </div>

            <!-- Quick Links -->
            <div>
                <h3 class="font-heading font-bold text-lg mb-4">Quick Links</h3>
                <ul class="space-y-2">
                    <li>
                        <a
                            href="/"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >Home</a>
                    </li>
                    <li>
                        <a
                            href="/what-we-do"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >What We Do</a>
                    </li>
                    <li>
                        <a
                            href="/our-work"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >Our Work</a>
                    </li>
                    <li>
                        <a
                            href="/about"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >About</a>
                    </li>
                </ul>
            </div>

            <!-- Services -->
            <div>
                <h3 class="font-heading font-bold text-lg mb-4">Services</h3>
                <ul class="space-y-2">
                    <li>
                        <a
                            href="/trades-we-serve"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >Trades We Serve</a>
                    </li>
                    <li>
                        <a
                            href="/reviews"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >Reviews</a>
                    </li>
                    <li>
                        <a
                            href="/contact"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >Contact</a>
                    </li>
                </ul>
            </div>

            <!-- Legal -->
            <div>
                <h3 class="font-heading font-bold text-lg mb-4">Legal</h3>
                <ul class="space-y-2">
                    <li>
                        <a
                            href="/privacy"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >Privacy Policy</a>
                    </li>
                    <li>
                        <a
                            href="/terms"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >Terms of Service</a>
                    </li>
                    <li>
                        <a
                            href="/sitemap"
                            class="text-gray-300 hover:text-[#f59f0a] transition-colors"
                            >Sitemap</a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Divider -->
        <div class="border-t border-gray-600 pt-8">
            <!-- Copyright -->
            <div class="text-center text-gray-400 text-sm">
                <p>&copy; 2024 Your Company Name. All rights reserved.</p>
            </div>
        </div>
    </div>
</footer>
