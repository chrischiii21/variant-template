                    <p class="text-xl font-heading font-bold">
                        {companyName}
                    </p>
                </div>
                <p
                    class="text-gray-400 text-base leading-relaxed mb-6 font-body"
                >
                    {tagline}
                </p>

                <!-- CTA Button -->
                <a
                    href="contact"
                    class="flex items-center gap-3 bg-accent px-4 py-3 hover:bg-[#d97706] transition-colors cursor-pointer"
                    aria-label={`Call us at ${phone} for a free quote`}
