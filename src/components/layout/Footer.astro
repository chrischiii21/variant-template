---
import { getCollection } from "astro:content";

interface Props {
    companyName?: string;
    tagline?: string;
    phone?: string;
    email?: string;
    address?: string;
    hours?: string;
}

const {
    companyName = "BUILDPRO",
    tagline = "High-converting websites built for contractors who want to dominate their local market.",
    phone = "(555) 123-4567",
    email = "info@buildpro.com",
    address = "123 Brooklyn New Street, USA",
    hours = "8:00 AM to 9:00 PM",
} = Astro.props;

const currentYear = new Date().getFullYear();

// Get latest trades and templates
const allTrades = await getCollection("trades");
const allTemplates = await getCollection("templates");

// Sort trades by order for services list (ascending)
const sortedTradesForServices = allTrades.sort(
    (a, b) => a.data.order - b.data.order,
);

// Sort trades by order (descending) for updates and templates by most recent
const sortedTrades = allTrades.sort((a, b) => b.data.order - a.data.order);
const sortedTemplates = [...allTemplates].reverse(); // Most recent last, so reverse

// Combine all updates with timestamps
const allUpdates = [
    ...sortedTrades.map((trade) => ({
        type: "trade",
        title: `New Trade Added: ${trade.data.name}`,
        image: trade.data.image,
        link: `/trades-we-serve/${trade.data.slug}`,
    })),
    ...sortedTemplates.map((template) => ({
        type: "template",
        title: `New Template: ${template.data.title}`,
        image: template.data.thumbnail,
        link: `/our-work`,
    })),
];

// Get the 2 most recent updates, prioritizing templates
const templateUpdates = allUpdates
    .filter((u) => u.type === "template")
    .slice(0, 2);
const tradeUpdates = allUpdates.filter((u) => u.type === "trade").slice(0, 2);

// Combine: show at least 1 template if available, then fill with trades
const updates = [];
if (templateUpdates.length > 0) {
    updates.push(templateUpdates[0]);
}
if (tradeUpdates.length > 0 && updates.length < 2) {
    updates.push(tradeUpdates[0]);
}
if (templateUpdates.length > 1 && updates.length < 2) {
    updates.push(templateUpdates[1]);
}
if (tradeUpdates.length > 1 && updates.length < 2) {
    updates.push(tradeUpdates[1]);
}
---

<footer class="bg-text text-white">
    <!-- Main Footer Content -->
    <div class="max-w-7xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-8">
            <!-- Company Info -->
            <div id="footer-company" class="lg:col-span-3">
