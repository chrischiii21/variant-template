                        ></path>
                    </svg>
                    <div>
                        <p
                            class="text-xs text-white/80 uppercase tracking-wide font-body"
                        >
                            Get a Free Quote
                        </p>
                        <p class="text-base font-heading font-bold text-white">
                            {phone}
                        </p>
                    </div>
                </a>
            </div>

            <!-- Links -->
            <div id="footer-links" class="lg:col-span-2">
                <p class="font-heading font-bold text-lg mb-4">Links</p>
                <ul class="space-y-2">
                    <li>
                        <a
                            href="/reviews"
                            class="text-gray-400 hover:text-accent transition-colors text-base font-body"
                            >Reviews</a
                        >
                    </li>
                    <li>
                        <a
                            href="/our-work"
                            class="text-gray-400 hover:text-accent transition-colors text-base font-body"
                            >Our Work</a
                        >
                    </li>
                    <li>
                        <a
                            href="/trades-we-serve"
                            class="text-gray-400 hover:text-accent transition-colors text-base font-body"
                            >Trades We Serve</a
                        >
                    </li>
                    <li>
                        <a
                            href="/what-we-do"
                            class="text-gray-400 hover:text-accent transition-colors text-base font-body"
                            >What We Do</a
                        >
                    </li>
                    <li>
                        <a
                            href="/contact"
                            class="text-gray-400 hover:text-accent transition-colors text-base font-body"
                            >Contact</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Services (Dynamic) -->
            <div id="footer-services" class="lg:col-span-2">
                <p class="font-heading font-bold text-lg mb-4">Services</p>
                <ul class="space-y-2">
                    {
                        sortedTradesForServices.map((trade) => (
                            <li>
                                <a
                                    href={`/trades-we-serve/${trade.data.slug}`}
                                    class="text-gray-400 hover:text-accent transition-colors text-base font-body"
                                >
                                    {trade.data.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Latest Updates -->
            <div id="footer-updates" class="lg:col-span-3">
                <p class="font-heading font-bold text-lg mb-4">
                    Latest Updates
                </p>
                <div class="space-y-3">
                    {
                        updates.map((update) => (
                            <a
                                href={update.link}
                                class="flex gap-3 group"
                                aria-label={update.title}
                            >
                                <img
                                    src={update.image}
                                    alt={`${update.type === "trade" ? "Trade service" : "Website template"} preview`}
                                    class="w-16 h-16 object-cover"
                                />
                                <div>
                                    <p class="text-xs text-accent uppercase mb-1 font-body">
                                        {update.type === "trade"
                                            ? "New Trade"
                                            : "New Template"}
                                    </p>
                                    <p class="text-base text-gray-300 group-hover:text-accent transition-colors line-clamp-2 font-body">
                                        {update.title}
                                    </p>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>

            <!-- Contact -->
            <div id="footer-contact" class="lg:col-span-2">
                <p class="font-heading font-bold text-lg mb-4">Contact</p>
                <div class="space-y-3">
                    <div class="flex items-start gap-2">
                        <svg
                            class="w-5 h-5 text-accent mt-0.5 shrink-0"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                            ></path>
                        </svg>
                        <a
                            href={`mailto:${email}`}
                            class="text-gray-400 hover:text-accent transition-colors text-base break-words font-body"
                            >{email}</a
                        >
                    </div>

                    <div class="flex items-start gap-2">
                        <svg
                            class="w-5 h-5 text-accent mt-0.5 shrink-0"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
