---
interface Feature {
    icon: string;
    title: string;
    description: string;
}

interface Props {
    title?: string;
    subtitle?: string;
    features?: Feature[];
}

const {
    title = "Why Choose Our Templates?",
    subtitle = "Built with your success in mind",
    features = [
        {
            icon: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z",
            title: "Mobile Optimized",
            description: "Perfect on all devices",
        },
        {
            icon: "M13 10V3L4 14h7v7l9-11h-7z",
            title: "Fast Loading",
            description: "Optimized performance",
        },
        {
            icon: "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01",
            title: "Easy Customization",
            description: "No coding required",
        },
        {
            icon: "M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z",
            title: "24/7 Support",
            description: "Always here to help",
        },
    ],
} = Astro.props;
---

<section class="py-16 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
            <h2 class="heading-h2 font-heading font-bold text-primary mb-4">
                {title}
            </h2>
            <p class="text-base md:text-xl text-gray-600">
                {subtitle}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {
                features.map((feature) => (
                    <div class="text-center">
                        <div class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center">
                            <svg
                                class="w-8 h-8 text-accent"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d={feature.icon}
                                />
                            </svg>
                        </div>
                        <h3 class="font-heading font-bold text-base md:text-lg text-primary mb-2">
                            {feature.title}
                        </h3>
                        <p class="text-sm text-gray-600">
                            {feature.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
