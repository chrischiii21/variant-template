---
import Button from "../ui/Button.astro";
---

<section class="pt-28 pb-20 px-6 bg-white font-body">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
      
      <div class="relative h-full flex items-stretch">
        <div class="relative w-[360px]">
          <img 
            src="https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?w=800&h=600&fit=crop" 
            alt="Web development workspace" 
            class="w-full h-full object-cover shadow-xl"
          />
        </div>

        <div class="absolute top-0 right-[5px] w-60">
          <img 
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=400&h=300&fit=crop" 
            alt="Digital team collaboration" 
            class="w-full h-[350px] object-cover shadow-xl hidden md:block"
          />
        </div>

        <!-- Stats Card - Hidden on mobile, shown as overlay on larger screens -->
        <div class="absolute bottom-0 right-[5px] bg-white shadow-xl p-5 w-60 h-[240px] hidden sm:block">
          <div class="text-center mb-2">
            <h3 class="text-lg font-bold text-primary">Customer Rating</h3>
          </div>
          
          <div class="w-full h-px mb-3 bg-primary opacity-20"></div>
          
          <div class="text-center mt-4">
            <div class="flex items-center justify-center gap-1 mb-1">
              <svg class="w-7 h-7 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
              <span class="text-4xl font-bold text-primary leading-none">4.9</span>
            </div>
            <p class="text-base text-gray-600 mb-3 text-center">(15k+ Reviews)</p>
            
            <!-- Overlapping Profile Icons -->
            <div class="flex items-center justify-center -space-x-2">
              <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=100&h=100&fit=crop&crop=faces" alt="Customer" class="w-10 h-10 rounded-full border-2 border-white object-cover" />
              <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=100&h=100&fit=crop&crop=faces" alt="Customer" class="w-10 h-10 rounded-full border-2 border-white object-cover" />
              <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&h=100&fit=crop&crop=faces" alt="Customer" class="w-10 h-10 rounded-full border-2 border-white object-cover" />
              <div class="w-10 h-10 rounded-full border-2 border-white bg-accent flex items-center justify-center">
                <span class="text-white text-sm font-bold">+</span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Mobile Stats Card - Shown below image on mobile only -->
        <div class="sm:hidden bg-white shadow-xl p-6 rounded-lg">
          <div class="text-center pt-2 mb-3">
            <h3 class="text-lg font-bold text-primary">Customer Rating</h3>
          </div>
          
          <div class="w-full h-px mb-3 bg-primary opacity-20"></div>
          
          <div class="text-center mt-4">
            <div class="flex items-center justify-center gap-1 mb-1">
              <svg class="w-7 h-7 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
              </svg>
              <span class="text-5xl font-bold text-primary leading-none">4.9</span>
            </div>
            <p class="text-base text-gray-600 mb-3 text-center">(500+ Reviews)</p>
            
            <!-- Overlapping Profile Icons -->
            <div class="flex items-center justify-center -space-x-2">
              <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=100&h=100&fit=crop&crop=faces" alt="Customer" class="w-10 h-10 rounded-full border-2 border-white object-cover" />
              <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=100&h=100&fit=crop&crop=faces" alt="Customer" class="w-10 h-10 rounded-full border-2 border-white object-cover" />
              <img src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&h=100&fit=crop&crop=faces" alt="Customer" class="w-10 h-10 rounded-full border-2 border-white object-cover" />
              <div class="w-10 h-10 rounded-full border-2 border-white bg-accent flex items-center justify-center">
                <span class="text-white text-sm font-bold">+</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div>
        <h2 class="heading-h2 font-bold mb-4 leading-tight -ml-1 text-primary">
          Digital Success<br>
          For Contractors<br>
          Who Dominate
        </h2>

        <p class="text-xl text-gray-600 mb-8 leading-relaxed max-w-[600px]">
          We build high-converting websites for contractors who want to dominate their local market. Quality websites that work as hard as you do.
        </p>

        <div class="grid grid-cols-2 gap-8 mb-8 max-w-[500px]">
          <div class="text-left">
            <div class="text-5xl font-bold mb-2 text-text">10+</div>
            <p class="text-base text-gray-600">Years of Experience</p>
          </div>

          <div class="text-left border-l-2 border-gray-200 pl-8">
            <div class="text-5xl font-bold mb-2 text-text">500+</div>
            <p class="text-base text-gray-600">Contractors Served</p>
          </div>
        </div>

        <div class="flex flex-wrap gap-4">
          <Button variant="accent" size="md" href="/about" icon={false}>
            Read More
          </Button>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  button:hover {
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
  }

  .counter {
    display: inline-block;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const counters = document.querySelectorAll('.counter, .counter-mobile');
    
    counters.forEach(counter => {
      const target = parseInt(counter.getAttribute('data-target') || '0');
      const duration = 1000; // 1 second (faster)
      const increment = target / (duration / 16); // 60fps
      let current = 0;
      
      const updateCounter = () => {
        current += increment;
        if (current < target) {
          counter.textContent = Math.floor(current).toString();
          requestAnimationFrame(updateCounter);
        } else {
          counter.textContent = target.toString();
        }
      };
      
      updateCounter();
    });
  });
</script>
