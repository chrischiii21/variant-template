---
import Button from "../ui/Button.astro";
---

<section class="py-20 px-4 bg-background font-body">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-stretch">
      
      <div class="relative h-full flex items-stretch">
        <div class="relative w-[360px]">
          <img 
            src="https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?w=800&h=600&fit=crop" 
            alt="Web development workspace" 
            class="w-full h-full object-cover shadow-xl"
          />
        </div>

        <div class="absolute top-0 right-[5px] w-60">
          <img 
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=400&h=300&fit=crop" 
            alt="Digital team collaboration" 
            class="w-full h-[350px] object-cover shadow-xl hidden md:block"
          />
        </div>

        <!-- Stats Card - Hidden on mobile, shown as overlay on larger screens -->
        <div class="absolute bottom-0 right-[5px] bg-white shadow-xl p-6 w-60 h-[230px] hidden sm:block">
          <div class="flex justify-between items-start mb-3">
            <h3 class="text-lg font-bold text-primary">Proven Results</h3>
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          
          <div class="w-full h-px mb-3 bg-primary opacity-20"></div>
          
          <div class="text-center mt-6">
            <div class="text-4xl font-bold mb-1 text-primary">
              <span class="counter" data-target="500">0</span>+
            </div>
            <p class="text-base text-gray-600">Contractors Served</p>
          </div>
        </div>
        
        <!-- Mobile Stats Card - Shown below image on mobile only -->
        <div class="sm:hidden bg-white shadow-xl p-6 rounded-lg">
          <div class="flex justify-between items-start mb-3">
            <h3 class="text-lg font-bold text-primary">Proven Results</h3>
            <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          
          <div class="w-full h-px mb-3 bg-primary opacity-20"></div>
          
          <div class="text-center mt-6">
            <div class="text-4xl font-bold mb-1 text-primary">
              <span class="counter-mobile inline-block min-w-[4rem] text-right tabular-nums" data-target="500">0</span>+
            </div>
            <p class="text-base text-gray-600">Contractors Served</p>
          </div>
        </div>
      </div>

      <div>
        <h2 class="heading-h2 font-bold mb-4 leading-tight -ml-1 text-primary">
          Digital Success<br>
          For Contractors<br>
          Who Dominate
        </h2>

        <p class="text-xl text-gray-600 mb-8 leading-relaxed max-w-[600px]">
          We build high-converting websites for contractors who want to dominate their local market. Quality websites that work as hard as you do.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <div class="flex items-start gap-3">
            <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-accent">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-text">High-Converting Design</h3>
              <p class="text-base text-gray-600">Websites built to turn visitors into leads and customers.</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-accent">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold mb-2 text-text">Local Market Domination</h3>
              <p class="text-base text-gray-600">Strategies that help you own your local service area.</p>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap gap-4">
          <Button variant="accent" size="sm" href="/about" icon={false}>
            Read More
          </Button>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  button:hover {
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
  }

  .counter {
    display: inline-block;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const counters = document.querySelectorAll('.counter, .counter-mobile');
    
    counters.forEach(counter => {
      const target = parseInt(counter.getAttribute('data-target') || '0');
      const duration = 1000; // 1 second (faster)
      const increment = target / (duration / 16); // 60fps
      let current = 0;
      
      const updateCounter = () => {
        current += increment;
        if (current < target) {
          counter.textContent = Math.floor(current).toString();
          requestAnimationFrame(updateCounter);
        } else {
          counter.textContent = target.toString();
        }
      };
      
      updateCounter();
    });
  });
</script>
