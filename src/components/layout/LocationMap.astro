---
interface Props {
    embedUrl?: string;
    title?: string;
}

const {
    embedUrl = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.9476519598093!2d-73.99185368459395!3d40.74117197932881!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c259a9b3117469%3A0xd134e199a405a163!2sEmpire%20State%20Building!5e0!3m2!1sen!2sus!4v1234567890123!5m2!1sen!2sus",
    title = "Company Location Map",
} = Astro.props;
---

<div class="bg-white shadow-lg overflow-hidden h-110">
    <iframe
        src={embedUrl}
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={title}></iframe>
</div>
