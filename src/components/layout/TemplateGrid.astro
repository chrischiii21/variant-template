---
interface Template {
    data: {
        title: string;
        description: string;
        thumbnail: string;
        liveDemoUrl: string;
        category: string;
    };
}

interface Props {
    templates: Template[];
    tradeName: string;
    showBrowseAllButton?: boolean;
}

const { templates, tradeName, showBrowseAllButton = true } = Astro.props;
---

{
    templates.length > 0 ? (
        <section class="py-16 px-6 bg-background">
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-12">
                    <span class="inline-block px-4 py-2 bg-accent/10 text-accent font-heading font-bold uppercase text-sm mb-4">
                        Website Templates
                    </span>
                    <h2 class="heading-h2 font-heading font-bold text-primary mb-4">
                        Ready-to-Launch {tradeName} Websites
                    </h2>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto">
                        Choose from our professionally designed templates. Each
                        one is mobile-optimized and built to convert visitors
                        into customers.
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {templates.map((template) => (
                        <a
                            href={template.data.liveDemoUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="bg-white shadow-md hover:shadow-xl transition-all duration-300 group block"
                        >
                            <div class="relative h-64 overflow-hidden bg-gray-200">
                                <div class="absolute top-4 right-4 z-10">
                                    <span class="bg-accent text-white px-3 py-1 text-xs font-heading font-bold uppercase">
                                        {template.data.category}
                                    </span>
                                </div>
                                <img
                                    src={template.data.thumbnail}
                                    alt={template.data.title}
                                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                />

                                <div class="absolute inset-0 bg-gradient-to-b from-primary/90 to-primary/95 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
                                    <div class="text-center px-6">
                                        <svg
                                            class="w-16 h-16 text-accent mx-auto mb-4"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                            stroke-width="2"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                            />
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                            />
                                        </svg>
                                        <p class="text-white text-xl font-heading font-bold uppercase tracking-wide">
                                            View Demo
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="p-6">
                                <h3 class="text-xl font-heading font-bold text-primary mb-2 group-hover:text-accent transition-colors">
                                    {template.data.title}
                                </h3>
                                <p class="text-base text-gray-600 line-clamp-2">
                                    {template.data.description}
                                </p>
                            </div>
                        </a>
                    ))}
                </div>

                {showBrowseAllButton && (
                    <div class="text-center mt-12">
                        <p class="text-base text-gray-600 mb-4">
                            Want to see templates for other industries?
                        </p>
                        <a
                            href="/our-work"
                            class="inline-block px-6 py-3 border-2 border-primary text-primary font-heading font-bold uppercase hover:bg-primary hover:text-white transition-colors"
                        >
                            Browse All Works
                        </a>
                    </div>
                )}
            </div>
        </section>
    ) : (
        <section class="py-16 px-6 bg-background">
            <div class="max-w-4xl mx-auto text-center">
                <div class="w-20 h-20 bg-accent/10 mx-auto mb-6 flex items-center justify-center">
                    <svg
                        class="w-10 h-10 text-accent"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 6v6m0 0v6m0-6h6m-6 0H6"
                        />
                    </svg>
                </div>
                <h2 class="text-3xl font-heading font-bold text-primary mb-4">
                    Templates Coming Soon
                </h2>
                <p class="text-xl text-gray-600 mb-8">
                    We're currently developing professional website templates
                    specifically for {tradeName.toLowerCase()} businesses. In
                    the meantime, check out our other industry templates.
                </p>
                <a
                    href="/our-work"
                    class="inline-block px-6 py-3 bg-accent text-white font-heading font-bold uppercase hover:bg-accent/90 transition-colors"
                >
                    View All Templates
                </a>
            </div>
        </section>
    )
}
