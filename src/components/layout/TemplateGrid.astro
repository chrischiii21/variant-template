---
import Button from "../ui/Button.astro";

interface Template {
    data: {
        title: string;
        description: string;
        thumbnail: string;
        liveDemoUrl: string;
        category: string;
    };
}

interface Props {
    templates: Template[];
    tradeName: string;
    showBrowseAllButton?: boolean;
}

const { templates, tradeName, showBrowseAllButton = true } = Astro.props;
---

{
    templates.length > 0 ? (
        <section class="py-16 px-6 bg-background overflow-x-hidden">
            <div class="max-w-7xl mx-auto">
                <div class="text-center mb-12">
                    <h2 class="heading-h2 font-heading font-bold text-primary mb-4">
                        {tradeName} Website Templates
                    </h2>
                    <p class="text-xl text-gray-600 mx-auto font-body">
                        Professional templates designed for your business
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {templates.map((template) => (
                        <a
                            href={template.data.liveDemoUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="bg-white shadow-md hover:shadow-xl transition-all duration-300 group block"
                        >
                            <div class="relative h-64 overflow-hidden bg-gray-200">
                                <div class="absolute top-4 right-4 z-10">
                                    <span class="bg-accent text-white px-3 py-1 text-xs font-heading font-bold uppercase">
                                        {template.data.category}
                                    </span>
                                </div>
                                <img
                                    src={template.data.thumbnail}
                                    alt={template.data.title}
                                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                                />

                                <div class="absolute inset-0 bg-gradient-to-b from-primary/90 to-primary/95 backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
                                    <div class="text-center px-6">
                                        <svg
                                            class="w-16 h-16 text-accent mx-auto mb-4"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                            stroke-width="2"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
                                            />
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
                                            />
                                        </svg>
                                        <p class="text-white text-xl font-heading font-bold uppercase tracking-wide">
                                            View Demo
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <div class="p-6">
                                <h3 class="text-xl font-heading font-bold text-primary mb-2 group-hover:text-accent transition-colors">
                                    {template.data.title}
                                </h3>
                                <p class="text-base text-gray-600 line-clamp-2 font-body">
                                    {template.data.description}
                                </p>
                            </div>
                        </a>
                    ))}
                </div>

                {showBrowseAllButton && (
                    <div class="text-center mt-12 overflow-hidden">
                        <p class="text-base text-gray-600 mb-4 font-body">
                            Want to see templates for other industries?
                        </p>
                        <Button variant="outline" size="md" href="/our-work">
                            Browse All Works
                        </Button>
                    </div>
                )}
            </div>
        </section>
    ) : (
        <section class="py-16 px-6 bg-background overflow-x-hidden">
            <div class="max-w-7xl mx-auto">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {/* Placeholder Card 1 */}
                    <div class="bg-white border-2 border-dashed border-gray-300">
                        <div class="relative h-64 bg-gray-100 flex items-center justify-center">
                            <svg
                                class="w-16 h-16 text-gray-300"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                                />
                            </svg>
                        </div>
                        <div class="p-6">
                            <div class="h-6 bg-gray-200 mb-3 w-3/4" />
                            <div class="h-4 bg-gray-100 mb-2" />
                            <div class="h-4 bg-gray-100 w-5/6" />
                        </div>
                    </div>

                    {/* Placeholder Card 2 - Center card with message */}
                    <div class="bg-white border-2 border-dashed border-accent/30">
                        <div class="relative h-64 bg-accent/5 flex items-center justify-center">
                            <div class="text-center px-6">
                                <div class="w-16 h-16 bg-accent/10 mx-auto mb-4 flex items-center justify-center">
                                    <svg
                                        class="w-8 h-8 text-accent"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 6v6m0 0v6m0-6h6m-6 0H6"
                                        />
                                    </svg>
                                </div>
                                <p class="text-base font-heading font-bold text-primary">
                                    Coming Soon
                                </p>
                            </div>
                        </div>
                        <div class="p-6">
                            <div class="h-6 bg-gray-200 mb-3 w-3/4 mx-auto" />
                            <div class="h-4 bg-gray-100 mb-2" />
                            <div class="h-4 bg-gray-100 w-5/6 mx-auto" />
                        </div>
                    </div>

                    {/* Placeholder Card 3 */}
                    <div class="bg-white border-2 border-dashed border-gray-300">
                        <div class="relative h-64 bg-gray-100 flex items-center justify-center">
                            <svg
                                class="w-16 h-16 text-gray-300"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1.5"
                                    d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                                />
                            </svg>
                        </div>
                        <div class="p-6">
                            <div class="h-6 bg-gray-200 mb-3 w-3/4" />
                            <div class="h-4 bg-gray-100 mb-2" />
                            <div class="h-4 bg-gray-100 w-5/6" />
                        </div>
                    </div>
                </div>

                <div class="text-center mt-12">
                    <p class="text-base text-gray-600 mb-6 font-body">
                        We're currently developing professional website
                        templates for {tradeName.toLowerCase()} businesses.
                    </p>
                    <Button variant="accent" size="md" href="/our-work">
                        Explore Other Industries
                    </Button>
                </div>
            </div>
        </section>
    )
}
