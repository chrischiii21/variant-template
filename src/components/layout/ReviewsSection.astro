---
const testimonials = [
    {
        name: "John Martinez",
        role: "HVAC Contractor",
        review: "BuildPro transformed my business completely. The website they created is professional, fast, and most importantly, it converts visitors into paying customers. I've closed 23 new clients in just 60 days! Absolutely worth it.",
        image: "https://images.unsplash.com/photo-1560250097-0b93528c311a?w=100&h=100&fit=crop",
    },
    {
        name: "Sarah Williams",
        role: "Plumbing Services",
        review: "Our Google ranking went from page 4 to #1 in less than three months. The results have been incredible - we've had to hire 3 more techs just to handle all the demand. This is the real deal. Best decision we ever made. Period.",
        image: "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=100&h=100&fit=crop",
    },
    {
        name: "Michael Chen",
        role: "Electrical Services",
        review: "Best investment I've ever made for my business. No more begging for leads in Facebook groups. Our new website brings in qualified leads every single day. We're busier than we've ever been. I should have done this sooner.",
        image: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&h=100&fit=crop",
    },
    {
        name: "Emma Rodriguez",
        role: "General Contractor",
        review: "Their paid ads strategy brought in $400k in projects in Q4 alone. This team operates on a different level. The website, the ads, the follow-up system - everything works together seamlessly. Outstanding. Highly recommended.",
        image: "https://images.unsplash.com/photo-1580489944761-15a19d654956?w=100&h=100&fit=crop",
    },
    {
        name: "David Thompson",
        role: "Roofing",
        review: "We launched just 3 years ago and we're already running circles around competitors who've been in business for 20 years. BuildPro gave us a website that makes us look like the established authority. Couldn't be happier.",
        image: "https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=100&h=100&fit=crop",
    },
    {
        name: "Lisa Park",
        role: "Landscaping",
        review: "We tripled our monthly revenue in just 4 months after launching our new website. The ROI speaks for itself. We're getting calls from customers who found us on Google, and they're ready to buy. This investment paid off quickly.",
        image: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&h=100&fit=crop",
    },
];
---

<section class="py-16 px-6 max-w-7xl mx-auto">
    <div class="mb-12">
        <div class="flex items-center justify-between flex-wrap gap-6">
            <div class="flex items-center gap-6">
                <div class="flex -space-x-4">
                    <div
                        class="w-16 h-16 rounded-full bg-primary border-4 border-white overflow-hidden"
                    >
                        <img
                            src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=100&h=100&fit=crop"
                            alt="Customer"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <div
                        class="w-16 h-16 rounded-full bg-secondary border-4 border-white overflow-hidden"
                    >
                        <img
                            src="https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=100&h=100&fit=crop"
                            alt="Customer"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <div
                        class="w-16 h-16 rounded-full bg-accent border-4 border-white overflow-hidden"
                    >
                        <img
                            src="https://images.unsplash.com/photo-1519085360753-af0119f7cbe7?w=100&h=100&fit=crop"
                            alt="Customer"
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>
                <div class="flex flex-col items-start gap-2">
                    <div class="flex gap-1">
                        {
                            [1, 2, 3, 4, 5].map(() => (
                                <svg
                                    class="w-7 h-7 text-accent"
                                    fill="currentColor"
                                    viewBox="0 0 20 20"
                                >
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            ))
                        }
                    </div>
                    <span
                        class="text-[22px] font-heading font-bold text-gray-600"
                        >4.8 rating</span
                    >
                </div>
            </div>
            <div class="text-right">
                <p class="text-xl font-body text-gray-600 mb-1">Trusted by</p>
                <p class="text-3xl font-heading font-bold text-primary">
                    500+ Contractors
                </p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
            testimonials.map((testimonial) => (
                <div class="bg-white p-8 shadow-lg flex flex-col h-full">
                    <div class="flex items-center mb-4">
                        {[1, 2, 3, 4, 5].map(() => (
                            <svg
                                class="w-6 h-6 text-accent"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                        ))}
                    </div>
                    <p class="font-body text-gray-600 mb-6 italic leading-relaxed flex-grow">
                        "{testimonial.review}"
                    </p>
                    <div class="flex items-center gap-3">
                        <img
                            src={testimonial.image}
                            alt={testimonial.name}
                            class="w-12 h-12 rounded-full object-cover"
                        />
                        <div>
                            <p class="font-heading font-bold text-primary">
                                {testimonial.name}
                            </p>
                            <p class="font-body text-[14px] text-gray-500">
                                {testimonial.role}
                            </p>
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</section>
