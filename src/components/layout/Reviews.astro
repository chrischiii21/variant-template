<section class="relative py-16 overflow-hidden bg-background">
  <div class="max-w-7xl mx-auto px-8 relative z-10 font-body">
    <!-- Header -->
    <div class="text-center mb-8">
      <h2 class="heading-h2 font-bold mb-4">
        <span class="text-[#1e3a5f]">What Our Clients Say</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-4xl mx-auto leading-relaxed">
        See how contractors like you are crushing it with websites that actually
        convert
      </p>
    </div>

    <!-- Carousel Container -->
    <div
      class="relative flex items-center justify-center py-20 px-4 overflow-hidden"
    >
      <div
        class="carousel-wrapper w-full max-w-7xl mx-auto relative overflow-hidden h-150"
      >
        <div class="carousel-track w-full h-full relative">
          {
            testimonials.map((testimonial, index) => (
              <div
                class="carousel-card bg-white p-8 flex flex-col w-full md:w-[380px] min-h-[500px] absolute transition-all duration-500 ease-in-out left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 max-w-sm md:max-w-none"
                data-index={index}
              >
                <div
                  class="flex gap-2 mb-6"
                  aria-label={`${testimonial.rating} star rating`}
                >
                  {Array.from({ length: testimonial.rating }).map(() => (
                    <span class="text-[28px] text-accent" aria-hidden="true">
                      ★
                    </span>
                  ))}
                </div>

                <blockquote class="text-base leading-[1.8] text-gray-700 mb-8 grow">
                  "{testimonial.text}"
                </blockquote>

                <div class="flex items-center gap-4 mt-auto">
                  <img
                    src={testimonial.image}
                    alt={`${testimonial.name}, ${testimonial.role}`}
                    class="w-14 h-14 rounded-full object-cover shrink-0"
                  />
                  <div>
                    <p class="font-bold text-base mb-1 text-text">
                      {testimonial.name}
                    </p>
                    <p class="text-[14px] text-gray-500">{testimonial.role}</p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <button
        class="carousel-prev absolute left-4 z-10 rounded-full p-3 shadow-lg hover:shadow-xl transition-all hover:scale-110 bg-white text-[#e63946] hidden"
        aria-label="Previous review"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
      </button>

      <button
        class="carousel-next absolute right-4 z-10 rounded-full p-3 shadow-lg hover:shadow-xl transition-all hover:scale-110 bg-white text-[#e63946] hidden"
        aria-label="Next review"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 5l7 7-7 7"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .carousel-track {
    will-change: transform;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const track = document.querySelector(
      ".carousel-track",
    ) as HTMLElement | null;
    const cards = document.querySelectorAll(".carousel-card");
    const prevBtn = document.querySelector(
      ".carousel-prev",
    ) as HTMLElement | null;
    const nextBtn = document.querySelector(
      ".carousel-next",
    ) as HTMLElement | null;
    const dots = document.querySelectorAll(".carousel-dot");

    if (!track || cards.length === 0) return;

    let currentIndex = 1; // Start with middle card as center
    const totalCards = cards.length;
    let autoSlideInterval: ReturnType<typeof setInterval> | null = null;

    function updateCarousel() {
      // Update card positions and styles in circular motion
      cards.forEach((card, index) => {
        const cardElement = card as HTMLElement;

        // Calculate position relative to current center
        let position = index - currentIndex;

        // Wrap around for circular effect
        if (position < -1) position += totalCards;
        if (position > 1) position -= totalCards;

        // Apply styles based on position
        if (position === 0) {
          // Center card
          cardElement.style.transform = "translateX(0) translateY(0) scale(1)";
          cardElement.style.opacity = "1";
          cardElement.style.zIndex = "10";
        } else if (position === -1) {
          // Left card
          cardElement.style.transform =
            "translateX(-110%) translateY(0) scale(0.85)";
          cardElement.style.opacity = "0.7";
          cardElement.style.zIndex = "5";
        } else if (position === 1) {
          // Right card
          cardElement.style.transform =
            "translateX(110%) translateY(0) scale(0.85)";
          cardElement.style.opacity = "0.7";
          cardElement.style.zIndex = "5";
        } else {
          // Hidden cards
          cardElement.style.transform =
            "translateX(0) translateY(0) scale(0.7)";
          cardElement.style.opacity = "0";
          cardElement.style.zIndex = "0";
        }
      });

      // Update dots
      dots.forEach((dot, index) => {
        if (index === currentIndex) {
          dot.classList.remove("bg-secondary");
          dot.classList.add("bg-primary");
        } else {
          dot.classList.remove("bg-primary");
          dot.classList.add("bg-secondary");
        }
      });
    }

    function nextSlide() {
      currentIndex = (currentIndex + 1) % totalCards;
      updateCarousel();
    }

    function prevSlide() {
      currentIndex = (currentIndex - 1 + totalCards) % totalCards;
      updateCarousel();
    }

    function startAutoSlide() {
      autoSlideInterval = setInterval(nextSlide, 5000);
    }

    function stopAutoSlide() {
      if (autoSlideInterval) {
        clearInterval(autoSlideInterval);
      }
    }

    if (prevBtn)
      prevBtn.addEventListener("click", () => {
        prevSlide();
        stopAutoSlide();
        startAutoSlide();
      });

    if (nextBtn)
      nextBtn.addEventListener("click", () => {
        nextSlide();
        stopAutoSlide();
        startAutoSlide();
      });

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        currentIndex = index;
        updateCarousel();
        stopAutoSlide();
        startAutoSlide();
      });
    });

    const wrapper = document.querySelector(
      ".carousel-wrapper",
    ) as HTMLElement | null;
    if (wrapper) {
      wrapper.addEventListener("mouseenter", stopAutoSlide);
      wrapper.addEventListener("mouseleave", startAutoSlide);
    }

    updateCarousel();
    startAutoSlide();
  });
</script>
