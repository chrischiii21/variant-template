---
// Navbar component
import { getCollection } from "astro:content";

// Get trades collection for dropdown
const trades = await getCollection("trades");

// Function to get trade icons
function getTradeIcon(tradeName: string) {
  const icons: Record<string, string> = {
    HVAC: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>',
    Plumbing:
      '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>',
    Electrical:
      '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
    Default:
      '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>',
  };
  return icons[tradeName] || icons["Default"];
}
---

<nav class="sticky top-0 z-50 relative h-29">
  <!-- Mobile Orange angled section -->
  <div class="absolute inset-0 bg-primary lg:hidden">
    <div
      class="absolute inset-y-0 right-0 w-32 bg-secondary"
      style="clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 2% 100%);"
    >
    </div>
  </div>

  <!-- Mobile white background for logo -->
  <div
    class="absolute inset-y-0 left-0 bg-white lg:hidden z-20"
    style="width: calc(100% - 4rem); clip-path: polygon(0% 0%, 85% 0%, 90% 100%, 0% 100%);"
  >
  </div>

  <!-- Desktop Content -->
  <div class="relative z-10 flex h-full w-full px-8 hidden lg:flex">
    <!-- White background for logo area - extends to left edge but follows logo -->
    <div
      class="absolute inset-y-0 right-0 bg-white z-20"
      style="left: calc(-50vw + 50%); width: calc(50vw - 50% + 320px); clip-path: polygon(0% 0%, 90% 0%, 100% 100%, 0% 100%);"
    >
    </div>

    <!-- Logo Section - fixed width - DESKTOP ONLY -->
    <div class="flex items-center h-full px-4 relative z-30 w-80">
      <a
        href="/"
        class="flex items-center text-primary hover:opacity-80 transition-opacity duration-300"
      >
        <img
          src="/images/logo.avif"
          alt="BUILDPRO"
          class="w-10 h-10 object-contain mr-2"
        />
        <span
          class="text-xl font-heading font-bold tracking-wider text-primary uppercase"
          >BUILDPRO</span
        >
      </a>
    </div>

    <!-- Right content section - starts after white background with proper spacing - DESKTOP ONLY -->
    <div class="flex flex-col h-full flex-1 ml-18">
      <!-- Top row with contact info and quote button -->
      <div class="flex items-center h-10 flex-1 relative justify-between">
        <!-- Black background extending from logo area to right edge -->
        <div
          class="absolute inset-y-0 bg-black hidden lg:block"
          style="left: -100vw; right: -100vw; width: 300vw;"
        >
        </div>

        <div
          class="flex items-center gap-16 h-full text-base justify-start relative z-10 ml-10"
        >
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-accent"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"
              ></path>
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"
              ></path>
            </svg>
            <p class="text-white text-base">needhelp@company.com</p>
          </div>
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 text-accent"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                clip-rule="evenodd"></path>
            </svg>
            <p class="text-white text-base">123 Brooklyn New Street, USA</p>
          </div>
        </div>
        <!-- Get a Free Quote - Large screens (1280px+) with absolute positioning -->
        <a
          href="/contact"
          class="hidden xl:flex absolute inset-y-0 right-0 bg-accent hover:bg-[#d97706] h-full items-center transition-colors duration-300"
          style="width: 12rem; right: calc(-50vw + 50%); width: calc(50vw - 50% + 25rem); clip-path: polygon(0% 0%, 90% 0%, 100% 100%, 3% 100%);"
        >
          <div class="flex items-center h-full relative z-10">
            <p
              class="text-white font-heading font-bold text-base ml-18 uppercase tracking-wide"
            >
              Get a Free Quote
            </p>
          </div>
        </a>

        <!-- Get a Free Quote - Small screens (below 1280px) with relative positioning -->
        <a
          href="/contact"
          class="xl:hidden bg-accent hover:bg-[#d97706] h-full flex items-center px-6 relative z-10 transition-colors duration-300"
          style="margin-right: calc(-50vw + 50%); padding-right: calc(50vw - 50% + 1.5rem); clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 10% 100%);"
        >
          <p
            class="text-white font-heading font-bold text-base ml-18 uppercase tracking-wide"
          >
            Get a Free Quote
          </p>
        </a>
      </div>

      <!-- Bottom row with navigation -->
      <div
        class="hidden lg:flex items-center space-x-8 text-white h-12 px-4 flex-1 relative"
      >
        <!-- Gray background extending from logo area to right edge -->
        <div
          class="absolute inset-y-0 bg-gray-700 hidden lg:block"
          style="left: calc(-100% - 2rem); right: calc(-100vw + 100%); width: calc(200vw + 100% + 2rem);"
        >
        </div>

        <div
          class="relative z-10 flex items-center space-x-8 w-full"
          style="margin-left: calc(50vw - 50% - 10px);"
        >
          <a
            href="/reviews"
            class="text-m font-medium hover:text-orange-400 transition-colors uppercase tracking-wide"
          >
            REVIEWS
          </a>
          <a
            href="/our-work"
            class="text-m font-medium hover:text-orange-400 transition-colors uppercase tracking-wide"
          >
            OUR WORK
          </a>
          <div class="relative group">
            <a
              href="/trades-we-serve"
              class="text-m font-medium hover:text-orange-400 transition-colors uppercase tracking-wide flex items-center"
            >
              TRADES WE SERVE
              <svg class="ml-1 w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
            <!-- Dropdown Menu -->
            <div
              class="absolute left-0 mt-2 w-56 bg-white rounded-lg shadow-lg border border-gray-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
            >
              <div class="py-2">
                {
                  trades.map((trade) => (
                    <a
                      href={`/trades-we-serve/${trade.data.slug}`}
                      class="flex items-center px-4 py-3 text-[#0A1931] hover:text-[#F48C06] hover:bg-gray-50 transition-colors duration-200"
                    >
                      <svg
                        class="w-6 h-6 mr-3 shrink-0"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <g
                          set:html={getTradeIcon(
                            trade.data.name.replace(" Services", ""),
                          )}
                        />
                      </svg>
                      <div>
                        <div class="font-medium text-[#0A1931]">
                          {trade.data.name}
                        </div>
                        <div class="text-base text-gray-500">
                          {trade.data.tagline}
                        </div>
                      </div>
                    </a>
                  ))
                }
              </div>
            </div>
          </div>
          <a
            href="/what-we-do"
            class="text-m font-medium hover:text-orange-400 transition-colors uppercase tracking-wide"
          >
            WHAT WE DO
          </a>
          <a
            href="/about"
            class="text-m font-medium hover:text-orange-400 transition-colors uppercase tracking-wide"
          >
            ABOUT
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Content -->
  <div
    class="lg:hidden flex items-center justify-between w-full h-full px-3 relative z-30"
  >
    <!-- Mobile Logo -->
    <div class="flex items-center min-w-0 flex-1 mr-2">
      <a href="/" class="flex items-center text-black min-w-0">
        <img
          src="/images/logo.avif"
          alt="BUILDPRO"
          class="w-6 h-6 sm:w-8 sm:h-8 object-contain mr-2 sm:mr-3 flex-shrink-0"
        />
        <span
          class="text-lg sm:text-xl font-heading font-bold tracking-wider text-primary uppercase truncate"
          >BUILDPRO</span
        >
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      type="button"
      id="mobile-menu-button"
      class="text-white hover:text-accent focus:outline-none flex-shrink-0 p-1"
    >
      <svg
        id="hamburger-icon"
        class="h-5 w-5 sm:h-6 sm:w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        id="close-icon"
        class="h-5 w-5 sm:h-6 sm:w-6 hidden"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div
    id="mobile-menu"
    class="lg:hidden absolute top-full left-0 w-full bg-white shadow-lg border-t border-gray-200 hidden z-40"
  >
    <div class="py-4 px-6 space-y-4">
      <a
        href="/reviews"
        class="block text-secondary hover:text-accent font-medium py-2 transition-colors"
      >
        Reviews
      </a>
      <a
        href="/our-work"
        class="block text-secondary hover:text-accent font-medium py-2 transition-colors"
      >
        Our Work
      </a>

      <!-- Mobile Trades Dropdown -->
      <div class="relative">
        <button
          id="mobile-trades-button"
          class="flex items-center justify-between w-full text-secondary hover:text-accent font-medium py-2 transition-colors"
        >
          Trades We Serve
          <svg
            id="mobile-trades-arrow"
            class="ml-1 h-4 w-4 transition-transform duration-200"
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path
              fill-rule="evenodd"
              d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
              clip-rule="evenodd"></path>
          </svg>
        </button>
        <div id="mobile-trades-dropdown" class="hidden mt-2 pl-4 space-y-2">
          {
            trades.map((trade) => (
              <a
                href={`/trades-we-serve/${trade.data.slug}`}
                class="flex items-center py-2 text-secondary hover:text-accent transition-colors"
              >
                <svg
                  class="w-4 h-4 mr-2 shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <g
                    set:html={getTradeIcon(
                      trade.data.name.replace(" Services", ""),
                    )}
                  />
                </svg>
                <div>
                  <div class="font-medium text-sm">{trade.data.name}</div>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <a
        href="/what-we-do"
        class="block text-secondary hover:text-accent font-medium py-2 transition-colors"
      >
        What We Do
      </a>
      <a
        href="/about"
        class="block text-secondary hover:text-accent font-medium py-2 transition-colors"
      >
        About
      </a>

      <!-- Mobile Get Quote Button -->
      <a
        href="/contact"
        class="block bg-accent text-white text-center font-medium py-3 px-6 rounded-lg hover:bg-[#d97706] transition-colors mt-4"
      >
        Get a Free Quote
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle functionality
  document.addEventListener("DOMContentLoaded", function () {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const hamburgerIcon = document.getElementById("hamburger-icon");
    const closeIcon = document.getElementById("close-icon");

    // Mobile trades dropdown functionality
    const mobileTradesButton = document.getElementById("mobile-trades-button");
    const mobileTradesDropdown = document.getElementById(
      "mobile-trades-dropdown",
    );
    const mobileTradesArrow = document.getElementById("mobile-trades-arrow");

    // Toggle mobile menu
    if (mobileMenuButton && mobileMenu && hamburgerIcon && closeIcon) {
      mobileMenuButton.addEventListener("click", function () {
        const isHidden = mobileMenu.classList.contains("hidden");

        if (isHidden) {
          // Show menu
          mobileMenu.classList.remove("hidden");
          hamburgerIcon.classList.add("hidden");
          closeIcon.classList.remove("hidden");
        } else {
          // Hide menu
          mobileMenu.classList.add("hidden");
          hamburgerIcon.classList.remove("hidden");
          closeIcon.classList.add("hidden");

          // Also close trades dropdown when closing main menu
          if (mobileTradesDropdown && mobileTradesArrow) {
            mobileTradesDropdown.classList.add("hidden");
            mobileTradesArrow.classList.remove("rotate-180");
          }
        }
      });
    }

    // Toggle mobile trades dropdown
    if (mobileTradesButton && mobileTradesDropdown && mobileTradesArrow) {
      mobileTradesButton.addEventListener("click", function () {
        const isHidden = mobileTradesDropdown.classList.contains("hidden");

        if (isHidden) {
          // Show dropdown
          mobileTradesDropdown.classList.remove("hidden");
          mobileTradesArrow.classList.add("rotate-180");
        } else {
          // Hide dropdown
          mobileTradesDropdown.classList.add("hidden");
          mobileTradesArrow.classList.remove("rotate-180");
        }
      });
    }

    // Close mobile menu when clicking outside
    document.addEventListener("click", function (event) {
      if (mobileMenu && !mobileMenu.classList.contains("hidden")) {
        const target = event.target as Node;
        const isClickInsideMenu = target && mobileMenu.contains(target);
        const isClickOnButton =
          mobileMenuButton && target && mobileMenuButton.contains(target);

        if (!isClickInsideMenu && !isClickOnButton) {
          mobileMenu.classList.add("hidden");
          if (hamburgerIcon && closeIcon) {
            hamburgerIcon.classList.remove("hidden");
            closeIcon.classList.add("hidden");
          }

          // Also close trades dropdown
          if (mobileTradesDropdown && mobileTradesArrow) {
            mobileTradesDropdown.classList.add("hidden");
            mobileTradesArrow.classList.remove("rotate-180");
          }
        }
      }
    });

    // Close mobile menu on window resize to desktop size
    window.addEventListener("resize", function () {
      if (window.innerWidth >= 1024) {
        if (mobileMenu) {
          mobileMenu.classList.add("hidden");
        }
        if (hamburgerIcon && closeIcon) {
          hamburgerIcon.classList.remove("hidden");
          closeIcon.classList.add("hidden");
        }

        if (mobileTradesDropdown && mobileTradesArrow) {
          mobileTradesDropdown.classList.add("hidden");
          mobileTradesArrow.classList.remove("rotate-180");
        }
      }
    });
  });
</script>
