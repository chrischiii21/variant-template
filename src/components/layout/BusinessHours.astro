---
interface Props {
    title?: string;
    emergencyText?: string;
}

const {
    title = "Business Hours",
    emergencyText = "Emergency Services: Available 24/7",
} = Astro.props;
---

<div class="bg-primary p-8 text-white">
    <h3 class="font-heading font-bold text-xl md:text-2xl mb-6">
        {title}
    </h3>
    <div class="space-y-3">
        <div
            class="flex justify-between items-center border-b border-white/20 pb-3"
        >
            <span class="text-base font-medium">Monday - Friday</span>
            <span class="text-base font-bold">8:00 AM - 5:00 PM</span>
        </div>
        <div
            class="flex justify-between items-center border-b border-white/20 pb-3"
        >
            <span class="text-base font-medium">Saturday</span>
            <span class="text-base font-bold">9:00 AM - 3:00 PM</span>
        </div>
        <div class="flex justify-between items-center">
            <span class="text-base font-medium">Sunday</span>
            <span class="text-base font-bold">Closed</span>
        </div>
    </div>
    <div class="mt-6 pt-6 border-t border-white/20">
        <p class="text-base text-white/90">
            <span class="font-bold">Emergency Services:</span>
            {emergencyText.replace("Emergency Services:", "").trim()}
        </p>
    </div>
</div>
