---
interface MissionItem {
    number: string;
    title: string;
    description: string;
}

interface Props {
    heading?: string;
    subheading?: string;
    items?: MissionItem[];
}

const {
    heading = "Our Mission",
    subheading = "We're committed to delivering excellence through these guiding principles",
    items = [
        {
            number: "1",
            title: "Enable Growth",
            description: "We provide contractors with professional digital tools that help them grow their businesses and reach more customers effectively.",
        },
        {
            number: "2",
            title: "Drive Results",
            description: "Every template we create is designed with conversion in mind, helping our clients generate more leads and close more deals.",
        },
        {
            number: "3",
            title: "Build Trust",
            description: "We create lasting partnerships by delivering quality work, transparent pricing, and exceptional ongoing support to every client we serve.",
        },
    ],
} = Astro.props;
---

<section class="py-16 px-6 bg-background">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
            <h2 class="heading-h2 font-heading font-bold text-[#1e3a5f] mb-4">
                {heading}
            </h2>
            <p class="text-xl font-body text-gray-600 max-w-5xl mx-auto">
                {subheading}
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
                items.map((item) => (
                    <div class="bg-white p-10 shadow-lg">
                        <div class="flex items-center gap-4 mb-6">
                            <div class="w-12 h-12 bg-accent flex items-center justify-center shrink-0">
                                <span class="text-2xl font-heading font-bold text-white">
                                    {item.number}
                                </span>
                            </div>
                            <h3 class="text-2xl font-heading font-bold text-[#1e3a5f]">
                                {item.title}
                            </h3>
                        </div>
                        <p class="font-body text-gray-600 text-[18px]">
                            {item.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
