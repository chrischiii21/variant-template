---
interface Props {
    title: string;
    breadcrumbs?: Array<{ label: string; href?: string }>;
    backgroundImage?: string;
}

const {
    title,
    backgroundImage,
    breadcrumbs = [
        { label: "HOME", href: "/" },
        { label: title.toUpperCase() },
    ],
} = Astro.props;
---

<section
    class="relative w-full h-96 md:h-[450px] flex items-center justify-center overflow-hidden"
    style={backgroundImage ? `background-image: url('${backgroundImage}'); background-size: cover; background-position: center;` : ''}
    class:list={[
        "relative w-full h-96 md:h-[450px] flex items-center justify-center overflow-hidden",
        backgroundImage ? "" : "bg-background"
    ]}
>
    <!-- Dark Overlay for background images -->
    {backgroundImage && <div class="absolute inset-0 bg-black/50"></div>}

    <!-- Textured Background Pattern -->
    <div class="absolute inset-0 opacity-5">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <pattern
                    id="grid"
                    width="40"
                    height="40"
                    patternUnits="userSpaceOnUse"
                >
                    <path
                        d="M 40 0 L 0 0 0 40"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1"
                        class="text-primary"></path>
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#grid)"></rect>
        </svg>
    </div>

    <!-- Diagonal Accent Stripes -->
    <div class="absolute inset-0 opacity-10">
        <div
            class="absolute top-0 left-0 w-full h-full"
            style="background: linear-gradient(135deg, transparent 0%, transparent 45%, var(--color-primary) 45%, var(--color-primary) 47%, transparent 47%, transparent 55%, var(--color-secondary) 55%, var(--color-secondary) 57%, transparent 57%, transparent 100%);"
        >
        </div>
    </div>

    <!-- Content -->
    <div class="relative z-10 w-full px-6 text-center">
        <!-- Breadcrumbs -->
        {
            breadcrumbs && breadcrumbs.length > 0 && (
                <nav
                    id="hero2-breadcrumbs"
                    class="flex items-center justify-center gap-2 mb-6"
                    aria-label="Breadcrumb"
                >
                    {breadcrumbs.map((crumb, index) => (
                        <>
                            {crumb.href ? (
                                <a
                                    href={crumb.href}
                                    class:list={[
                                        "text-base md:text-xl font-heading font-bold uppercase tracking-wider transition-colors",
                                        backgroundImage ? "text-white hover:text-accent" : "text-secondary hover:text-accent"
                                    ]}
                                >
                                    {crumb.label}
                                </a>
                            ) : (
                                <span 
                                    class:list={[
                                        "text-base md:text-xl font-heading font-bold uppercase tracking-wider",
                                        backgroundImage ? "text-accent" : "text-primary"
                                    ]}
                                >
                                    {crumb.label}
                                </span>
                            )}
                            {index < breadcrumbs.length - 1 && (
                                <svg
                                    class="w-3 h-3 text-accent"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 5l7 7-7 7"
                                    />
                                </svg>
                            )}
                        </>
                    ))}
                </nav>
            )
        }

        <!-- Page Title -->
        <h1
            id="hero2-title"
            class:list={[
                "heading-h1 font-heading font-bold tracking-wider uppercase",
                backgroundImage ? "text-white" : "text-primary"
            ]}
        >
            {title}
        </h1>
    </div>

    <!-- Bottom Accent Bar -->
    <div
        class="absolute bottom-0 left-0 w-full h-2 bg-gradient-to-r from-primary via-accent to-secondary"
    >
    </div>
</section>
<script>
  // Animation removed - gsap not installed
</script>