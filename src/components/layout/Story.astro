---
interface Props {
    heading?: string;
    subheading?: string;
    story?: string[];
    image?: string;
    imageAlt?: string;
}

const {
    heading = "Our Story",
    subheading = "How We Started Building Digital Solutions for Contractors",
    story = [
        "Founded in 2014, we started with a simple observation: contractors are experts at their craft, but many struggle to showcase their work online. We saw talented professionals losing business to competitors with better websites.",
        "What began as a small web design studio has grown into a specialized agency focused exclusively on the trades industry. We've learned what works, what converts, and what contractors actually need to succeed online.",
        "Today, we're proud to serve hundreds of contractors across the country, helping them build their digital presence and grow their businesses. Every website we create is backed by years of industry knowledge and real-world results.",
    ],
    image = "/images/about1.avif",
    imageAlt = "Our team working on contractor website designs",
} = Astro.props;
---

<section class="py-20 px-6 bg-white relative overflow-hidden">
    <!-- Decorative Background Elements -->
    <div
        class="absolute top-20 left-0 w-[500px] h-[500px] bg-accent/5 rounded-full blur-3xl -z-10"
    >
    </div>
    <div
        class="absolute bottom-20 right-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-3xl -z-10"
    >
    </div>

    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
            <!-- Content Side - Left -->
            <div class="lg:col-span-5 space-y-8">
                <!-- Header -->
                <div>
                    <div class="inline-flex items-center gap-3 mb-6">
                        <div class="w-12 h-1 bg-accent"></div>
                        <span
                            class="font-body text-accent font-bold text-base uppercase tracking-wider"
                        >
                            About Us
                        </span>
                    </div>
                    <h2
                        class="heading-h2 font-heading font-bold text-primary mb-6 leading-tight"
                    >
                        {heading}
                    </h2>
                    <div class="w-20 h-1.5 bg-accent mb-6"></div>
                    <p
                        class="text-subtitle font-body text-secondary leading-relaxed"
                    >
                        {subheading}
                    </p>
                </div>

                <!-- Story Paragraphs -->
                <div class="space-y-5">
                    {
                        story.map((paragraph, index) => (
                            <div class="flex gap-4">
                                <div class="flex-shrink-0 w-2 h-2 bg-accent rounded-full mt-2.5" />
                                <p class="font-body text-gray-600 text-lg leading-relaxed">
                                    {paragraph}
                                </p>
                            </div>
                        ))
                    }
                </div>

                <!-- Stats Row -->
                <div class="grid grid-cols-2 gap-6 pt-6">
                    <div class="bg-primary/5 p-6 border-t-4 border-primary">
                        <p
                            class="text-4xl font-heading font-bold text-primary mb-2"
                        >
                            500+
                        </p>
                        <p class="font-body text-gray-600">Happy Clients</p>
                    </div>
                    <div class="bg-accent/5 p-6 border-t-4 border-accent">
                        <p
                            class="text-4xl font-heading font-bold text-accent mb-2"
                        >
                            10+
                        </p>
                        <p class="font-body text-gray-600">Years Experience</p>
                    </div>
                </div>
            </div>

            <!-- Image Side - Right -->
            <div class="lg:col-span-7 relative">
                <div class="relative">
                    <!-- Main Image Container with Creative Layout -->
                    <div class="relative">
                        <!-- Primary Image -->
                        <div class="relative ml-0 lg:ml-12 group">
                            <div
                                class="absolute -inset-4 bg-gradient-to-br from-accent/20 to-primary/20 blur-xl opacity-50 group-hover:opacity-75 transition-opacity duration-500"
                            >
                            </div>
                            <div class="relative overflow-hidden shadow-2xl">
                                <img
                                    src={image}
                                    alt={imageAlt}
                                    class="w-full h-[600px] object-cover transition-transform duration-700 group-hover:scale-105"
                                />
                                <!-- Overlay Pattern -->
                                <div
                                    class="absolute inset-0 bg-gradient-to-tr from-primary/30 via-transparent to-accent/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                                >
                                </div>
                            </div>
                        </div>

                        <!-- Floating Accent Box -->
                        <div
                            class="absolute -left-8 top-16 w-32 h-32 bg-accent hidden lg:block"
                        >
                        </div>

                        <!-- Decorative Border Frame -->
                        <div
                            class="absolute -right-6 -bottom-6 w-48 h-48 border-8 border-primary/20 hidden lg:block"
                        >
                        </div>

                        <!-- Experience Badge - Floating -->
                        <div
                            class="absolute -left-6 bottom-20 bg-white p-8 shadow-2xl hidden lg:block z-10 border-l-4 border-accent"
                        >
                            <div class="text-center">
                                <div
                                    class="w-20 h-20 bg-accent mx-auto mb-4 flex items-center justify-center"
                                >
                                    <svg
                                        class="w-10 h-10 text-white"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                    >
                                        <path
                                            d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                                        ></path>
                                    </svg>
                                </div>
                                <p
                                    class="font-heading font-bold text-primary text-2xl mb-1"
                                >
                                    4.9/5
                                </p>
                                <p class="font-body text-gray-600 text-sm">
                                    Client Rating
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Highlights - Positioned Below Image -->
                <div class="mt-12 grid grid-cols-1 gap-4">
                    <div
                        class="flex items-center gap-4 bg-white p-5 shadow-lg border-l-4 border-accent hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
                    >
                        <div
                            class="w-16 h-16 bg-accent flex items-center justify-center shrink-0"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h4
                                class="font-heading font-bold text-primary text-lg mb-1"
                            >
                                Industry Expertise
                            </h4>
                            <p class="font-body text-gray-600 text-sm">
                                Deep understanding of contractor needs
                            </p>
                        </div>
                    </div>

                    <div
                        class="flex items-center gap-4 bg-white p-5 shadow-lg border-l-4 border-primary hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
                    >
                        <div
                            class="w-16 h-16 bg-primary flex items-center justify-center shrink-0"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"
                                ></path>
                                <path
                                    fill-rule="evenodd"
                                    d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm9.707 5.707a1 1 0 00-1.414-1.414L9 12.586l-1.293-1.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h4
                                class="font-heading font-bold text-primary text-lg mb-1"
                            >
                                Proven Results
                            </h4>
                            <p class="font-body text-gray-600 text-sm">
                                Track record of business growth
                            </p>
                        </div>
                    </div>

                    <div
                        class="flex items-center gap-4 bg-white p-5 shadow-lg border-l-4 border-secondary hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
                    >
                        <div
                            class="w-16 h-16 bg-secondary flex items-center justify-center shrink-0"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="currentColor"
                                viewBox="0 0 20 20"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zm-2 4a5 5 0 00-4.546 2.916A5.986 5.986 0 0010 16a5.986 5.986 0 004.546-2.084A5 5 0 0010 11z"
                                    clip-rule="evenodd"></path>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h4
                                class="font-heading font-bold text-primary text-lg mb-1"
                            >
                                Ongoing Support
                            </h4>
                            <p class="font-body text-gray-600 text-sm">
                                Dedicated to your long-term success
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
