---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
import TradeCard from "../components/ui/TradeCard.astro";
import CTA from "../components/layout/CTA.astro";
import { getCollection } from "astro:content";

// Get all trades and templates
const allTrades = await getCollection("trades");
const allTemplates = await getCollection("templates");

// Sort trades by order
const sortedTrades = allTrades.sort((a, b) => a.data.order - b.data.order);

// Count templates per trade
const tradesWithCount = sortedTrades.map((trade) => {
    const templateCount = allTemplates.filter(
        (template) =>
            template.data.trade.toLowerCase() === trade.data.slug.toLowerCase(),
    ).length;

    return {
        name: trade.data.name,
        slug: trade.data.slug,
        tagline: trade.data.tagline,
        templates: templateCount,
        image: trade.data.image,
    };
});
---

<BaseLayout
    title="Trades We Serve | Professional Website Templates for Contractors"
    description="Specialized website templates built for HVAC, plumbing, electrical, roofing, and other home service contractors. Industry-specific designs that convert visitors into customers."
>
    <Hero2
        title="Trades We Serve"
        breadcrumbs={[
            { label: "HOME", href: "/" },
            { label: "TRADES WE SERVE" },
        ]}
    />

    <!-- Introduction Section -->
    <section class="py-16 px-6 max-w-4xl mx-auto text-center">
        <h2
            class="text-2xl md:text-4xl font-heading font-bold text-[var(--color-primary)] mb-6"
        >
            Built for Your Industry
        </h2>
        <p class="text-lg text-gray-700 mb-4">
            We understand that every trade has unique needs. That's why we've
            created specialized website templates designed specifically for your
            industry, with features and content that speak directly to your
            customers.
        </p>
        <p class="text-base text-gray-600">
            Each template includes industry-specific service pages, optimized
            lead capture forms, and content that positions you as the local
            expert homeowners trust.
        </p>
    </section>

    <!-- Trade Cards Section -->
    <section class="py-12 px-6 max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                tradesWithCount.map((trade) => (
                    <TradeCard
                        name={trade.name}
                        slug={trade.slug}
                        image={trade.image}
                        templateCount={trade.templates}
                    />
                ))
            }
        </div>
    </section>

    <!-- Why Industry-Specific Section -->
    <section class="py-20 px-6 bg-white">
        <div class="max-w-6xl mx-auto">
            <div class="text-center mb-16">
                <h2
                    class="text-2xl md:text-4xl font-heading font-bold text-[var(--color-primary)] mb-4"
                >
                    Why Industry-Specific Templates Matter
                </h2>
                <p class="text-lg text-gray-600 max-w-3xl mx-auto">
                    Generic websites don't convert. Your customers have specific
                    needs and questions based on your trade. Our templates
                    address them directly.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
                <div class="flex items-start gap-4">
                    <div
                        class="w-16 h-16 bg-[var(--color-accent)] shrink-0 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <h3
                            class="font-heading font-bold text-xl text-[var(--color-primary)] mb-3"
                        >
                            Industry Language That Converts
                        </h3>
                        <p class="text-base text-gray-600 leading-relaxed">
                            Content written in the exact terminology your
                            customers understand and search for online. No
                            generic fluff - just language that resonates with
                            homeowners looking for your specific services.
                        </p>
                    </div>
                </div>

                <div class="flex items-start gap-4">
                    <div
                        class="w-16 h-16 bg-[var(--color-accent)] shrink-0 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <div>
                        <h3
                            class="font-heading font-bold text-xl text-[var(--color-primary)] mb-3"
                        >
                            Optimized Lead Capture Forms
                        </h3>
                        <p class="text-base text-gray-600 leading-relaxed">
                            Lead capture forms designed specifically for your
                            services. Ask the right questions to qualify leads
                            and gather the information you need to provide
                            accurate estimates.
                        </p>
                    </div>
                </div>

                <div class="flex items-start gap-4">
                    <div
                        class="w-16 h-16 bg-[var(--color-accent)] shrink-0 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <h3
                            class="font-heading font-bold text-xl text-[var(--color-primary)] mb-3"
                        >
                            SEO Built for Your Trade
                        </h3>
                        <p class="text-base text-gray-600 leading-relaxed">
                            Pre-optimized for the exact search terms your
                            potential customers use. Rank higher for "[Your
                            City] + [Your Service]" searches that drive
                            qualified local traffic to your site.
                        </p>
                    </div>
                </div>

                <div class="flex items-start gap-4">
                    <div
                        class="w-16 h-16 bg-[var(--color-accent)] shrink-0 flex items-center justify-center"
                    >
                        <svg
                            class="w-8 h-8 text-white"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                            ></path>
                        </svg>
                    </div>
                    <div>
                        <h3
                            class="font-heading font-bold text-xl text-[var(--color-primary)] mb-3"
                        >
                            Industry-Specific Trust Signals
                        </h3>
                        <p class="text-base text-gray-600 leading-relaxed">
                            Showcase the certifications, licenses, and
                            credentials that matter most in your industry. Build
                            instant credibility with trust signals your
                            customers actually care about.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Comparison Table -->
            <div class="bg-gray-50 p-8 md:p-12">
                <h3
                    class="text-2xl md:text-3xl font-heading font-bold text-[var(--color-primary)] mb-8 text-center"
                >
                    Generic vs Industry-Specific Templates
                </h3>
                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b-2 border-gray-300">
                                <th
                                    class="text-left py-4 px-4 font-heading font-bold text-lg"
                                ></th>
                                <th
                                    class="text-center py-4 px-4 font-heading font-bold text-lg text-gray-500"
                                    >Generic Template</th
                                >
                                <th
                                    class="text-center py-4 px-4 font-heading font-bold text-lg text-[var(--color-accent)]"
                                    >Industry-Specific</th
                                >
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b border-gray-200">
                                <td class="py-4 px-4 font-medium"
                                    >Industry Terminology</td
                                >
                                <td class="text-center py-4 px-4">
                                    <span class="text-2xl text-gray-400">✗</span
                                    >
                                </td>
                                <td class="text-center py-4 px-4">
                                    <span
                                        class="text-2xl text-[var(--color-accent)]"
                                        >✓</span
                                    >
                                </td>
                            </tr>
                            <tr class="border-b border-gray-200">
                                <td class="py-4 px-4 font-medium"
                                    >Service-Specific Forms</td
                                >
                                <td class="text-center py-4 px-4">
                                    <span class="text-2xl text-gray-400">✗</span
                                    >
                                </td>
                                <td class="text-center py-4 px-4">
                                    <span
                                        class="text-2xl text-[var(--color-accent)]"
                                        >✓</span
                                    >
                                </td>
                            </tr>
                            <tr class="border-b border-gray-200">
                                <td class="py-4 px-4 font-medium"
                                    >Trade-Specific SEO</td
                                >
                                <td class="text-center py-4 px-4">
                                    <span class="text-2xl text-gray-400">✗</span
                                    >
                                </td>
                                <td class="text-center py-4 px-4">
                                    <span
                                        class="text-2xl text-[var(--color-accent)]"
                                        >✓</span
                                    >
                                </td>
                            </tr>
                            <tr class="border-b border-gray-200">
                                <td class="py-4 px-4 font-medium"
                                    >Industry Certifications</td
                                >
                                <td class="text-center py-4 px-4">
                                    <span class="text-2xl text-gray-400">✗</span
                                    >
                                </td>
                                <td class="text-center py-4 px-4">
                                    <span
                                        class="text-2xl text-[var(--color-accent)]"
                                        >✓</span
                                    >
                                </td>
                            </tr>
                            <tr>
                                <td class="py-4 px-4 font-medium"
                                    >Conversion Optimization</td
                                >
                                <td class="text-center py-4 px-4">
                                    <span class="text-2xl text-gray-400">✗</span
                                    >
                                </td>
                                <td class="text-center py-4 px-4">
                                    <span
                                        class="text-2xl text-[var(--color-accent)]"
                                        >✓</span
                                    >
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <CTA
        title="Ready to Get Your Industry-Specific Website?"
        subtitle="Choose your trade and explore templates designed specifically for your business"
        primaryCtaText="Browse All Templates"
        primaryCtaLink="/our-work"
        secondaryCtaText="Contact Us"
        secondaryCtaLink="/contact"
    />
</BaseLayout>
