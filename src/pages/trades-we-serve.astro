---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
import { getCollection } from "astro:content";

// Get all trades and templates
const allTrades = await getCollection("trades");
const allTemplates = await getCollection("templates");

// Sort trades by order
const sortedTrades = allTrades.sort((a, b) => a.data.order - b.data.order);

// Count templates per trade
const tradesWithCount = sortedTrades.map((trade) => {
    const templateCount = allTemplates.filter(
        (template) =>
            template.data.trade.toLowerCase() === trade.data.slug.toLowerCase(),
    ).length;

    return {
        name: trade.data.name,
        slug: trade.data.slug,
        tagline: trade.data.tagline,
        templates: templateCount,
    };
});
---

<BaseLayout
    title="Trades We Serve | Your Company"
    description="Explore the different trades and services we offer"
>
    <Hero2
        title="Trades We Serve"
        backgroundImage="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1920&h=1080&fit=crop&q=80"
        breadcrumbs={[
            { label: "HOME", href: "/" },
            { label: "TRADES WE SERVE" },
        ]}
    />

    <section class="py-16 px-6 max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                tradesWithCount.map((trade) => (
                    <a
                        href={`/trades-we-serve/${trade.slug}`}
                        class="bg-white p-8 shadow-lg hover:shadow-xl transition-shadow cursor-pointer"
                    >
                        <h3 class="font-heading font-bold text-xl md:text-2xl mb-4 text-[var(--color-primary)]">
                            {trade.name}
                        </h3>
                        <p class="text-base text-gray-600 mb-3">
                            {trade.tagline}
                        </p>
                        <p class="text-sm text-gray-500">
                            {trade.templates}{" "}
                            {trade.templates === 1 ? "Template" : "Templates"}{" "}
                            Available
                        </p>
                    </a>
                ))
            }
        </div>
    </section>
</BaseLayout>
