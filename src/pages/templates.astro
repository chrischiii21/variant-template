---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero2 from '../components/layout/Hero2.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="All Templates | Your Company" description="Browse our complete collection of professional website templates for home services and trades">
	<Hero2 
		title="All Templates"
		backgroundImage="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1920&h=1080&fit=crop&q=80"
		breadcrumbs={[
			{ label: "HOME", href: "/" },
			{ label: "TEMPLATES" }
		]}
	/>
	
	<!-- Filter Bar -->
	<section class="py-8 px-6 bg-white border-b">
		<div class="max-w-7xl mx-auto">
			<div class="flex flex-wrap gap-4 items-center justify-between">
				<div class="flex flex-wrap gap-3">
					<button class="px-6 py-2 bg-[var(--color-accent)] text-white font-heading font-bold uppercase text-xl">All</button>
					<button class="px-6 py-2 bg-gray-200 text-gray-700 font-heading font-bold uppercase text-xl hover:bg-gray-300">HVAC</button>
					<button class="px-6 py-2 bg-gray-200 text-gray-700 font-heading font-bold uppercase text-xl hover:bg-gray-300">Plumbing</button>
					<button class="px-6 py-2 bg-gray-200 text-gray-700 font-heading font-bold uppercase text-xl hover:bg-gray-300">Electrical</button>
					<button class="px-6 py-2 bg-gray-200 text-gray-700 font-heading font-bold uppercase text-xl hover:bg-gray-300">Roofing</button>
				</div>
				<select class="px-4 py-2 border border-gray-300 font-heading text-base">
					<option>Sort by: Popular</option>
					<option>Sort by: Newest</option>
					<option>Sort by: Price</option>
				</select>
			</div>
		</div>
	</section>

	<!-- Templates Grid -->
	<section class="py-16 px-6 bg-[var(--color-background)]">
		<div class="max-w-7xl mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{[...Array(12)].map((_, i) => (
					<div class="bg-white shadow-lg hover:shadow-2xl transition-all duration-300 group">
						<!-- Template Preview -->
						<div class="relative h-64 overflow-hidden bg-gray-200">
							<div class="absolute top-4 right-4 z-10">
								<span class="bg-[var(--color-accent)] text-white px-3 py-1 text-xs font-heading font-bold uppercase">Popular</span>
							</div>
							<div class="w-full h-full flex items-center justify-center text-gray-400">
								<p>Template Preview {i + 1}</p>
							</div>
						</div>

						<!-- Template Info -->
						<div class="p-6">
							<div class="flex items-center gap-2 mb-3">
								<span class="text-xs font-heading font-bold uppercase text-[var(--color-primary)] bg-blue-50 px-2 py-1">HVAC</span>
								<span class="text-xs text-gray-500">Mobile Optimized</span>
							</div>
							<h3 class="text-xl font-heading font-bold text-[var(--color-primary)] mb-2">Professional HVAC Template</h3>
							<p class="text-base text-gray-600 mb-4">Perfect for heating and cooling contractors. Includes booking form and service areas.</p>
							
							<div class="flex items-center justify-between mb-4">
								<div class="flex items-center gap-1">
									{[...Array(5)].map(() => (
										<span class="text-[var(--color-accent)] text-base">★</span>
									))}
									<span class="text-sm text-gray-600 ml-2">(47 reviews)</span>
								</div>
							</div>

							<div class="flex items-center justify-between">
								<p class="text-2xl font-heading font-bold text-[var(--color-primary)]">$149</p>
								<Button variant="accent" size="sm" href={`/templates/template-${i + 1}`} icon={false}>View Demo</Button>
							</div>
						</div>
					</div>
				))}
			</div>

			<!-- Pagination -->
			<div class="flex justify-center gap-2 mt-12">
				<button class="px-4 py-2 bg-[var(--color-primary)] text-white font-heading font-bold">1</button>
				<button class="px-4 py-2 bg-gray-200 text-gray-700 font-heading font-bold hover:bg-gray-300">2</button>
				<button class="px-4 py-2 bg-gray-200 text-gray-700 font-heading font-bold hover:bg-gray-300">3</button>
				<button class="px-4 py-2 bg-gray-200 text-gray-700 font-heading font-bold hover:bg-gray-300">Next</button>
			</div>
		</div>
	</section>

	<!-- Trust Section -->
	<section class="py-16 px-6 bg-white">
		<div class="max-w-6xl mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-4 gap-8 text-center">
				<div>
					<div class="w-16 h-16 bg-[var(--color-accent)]/10 mx-auto mb-4 flex items-center justify-center">
						<svg class="w-8 h-8 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
						</svg>
					</div>
					<h3 class="font-heading font-bold text-[var(--color-primary)] mb-2">Money-Back Guarantee</h3>
					<p class="text-sm text-gray-600">30-day refund policy</p>
				</div>
				<div>
					<div class="w-16 h-16 bg-[var(--color-accent)]/10 mx-auto mb-4 flex items-center justify-center">
						<svg class="w-8 h-8 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
						</svg>
					</div>
					<h3 class="font-heading font-bold text-[var(--color-primary)] mb-2">24/7 Support</h3>
					<p class="text-sm text-gray-600">Always here to help</p>
				</div>
				<div>
					<div class="w-16 h-16 bg-[var(--color-accent)]/10 mx-auto mb-4 flex items-center justify-center">
						<svg class="w-8 h-8 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
						</svg>
					</div>
					<h3 class="font-heading font-bold text-[var(--color-primary)] mb-2">Free Updates</h3>
					<p class="text-sm text-gray-600">Lifetime template updates</p>
				</div>
				<div>
					<div class="w-16 h-16 bg-[var(--color-accent)]/10 mx-auto mb-4 flex items-center justify-center">
						<svg class="w-8 h-8 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
						</svg>
					</div>
					<h3 class="font-heading font-bold text-[var(--color-primary)] mb-2">Easy Customization</h3>
					<p class="text-sm text-gray-600">No coding required</p>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
