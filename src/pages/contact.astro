---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
import ContactCards from "../components/layout/ContactCards.astro";
import ContactForm from "../components/layout/ContactForm.astro";
import LocationMap from "../components/layout/LocationMap.astro";
import BusinessHours from "../components/layout/BusinessHours.astro";
import SocialLinks from "../components/layout/SocialLinks.astro";
---

<BaseLayout
    title="Contact Us | Your Company"
    description="Get in touch with our team"
>
    <Hero2
        title="Let's Build Something Together"
        breadcrumbs={[{ label: "HOME", href: "/" }, { label: "CONTACT US" }]}
    />

    <!-- Contact Cards Section -->
    <ContactCards />

    <!-- Form and Map Section -->
    <section id="contact-form" class="py-16 px-6">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                <!-- Contact Form -->
                <ContactForm />

                <!-- Map and Info -->
                <div class="space-y-8">
                    <!-- Map -->
                    <LocationMap />

                    <!-- Business Hours -->
                    <BusinessHours />

                    <!-- Social Media -->
                    <SocialLinks />
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
