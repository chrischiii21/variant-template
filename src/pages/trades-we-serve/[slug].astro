---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero2 from "../../components/layout/Hero2.astro";
import CTA from "../../components/layout/CTA.astro";
import StatsBar from "../../components/layout/StatsBar.astro";
import TemplateGrid from "../../components/layout/TemplateGrid.astro";
import ServiceFeatures from "../../components/layout/ServiceFeatures.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const allTrades = await getCollection("trades");

    return allTrades.map((trade) => ({
        params: { slug: trade.data.slug },
        props: { trade: trade.data },
    }));
}

const { trade } = Astro.props;

// Get all templates for this trade
const allTemplates = await getCollection("templates");
const tradeTemplates = allTemplates.filter(
    (template) => template.data.trade === trade.slug,
);

// Prepare stats data
const stats = [
    { value: "500+", label: "Projects Completed" },
    { value: "98%", label: "Customer Satisfaction" },
    {
        value: tradeTemplates.length.toString(),
        label: "Website Templates Available",
    },
];
---

<BaseLayout
    title={`${trade.name} | Your Company`}
    description={trade.hoverDescription}
>
    <Hero2
        title={trade.name}
        breadcrumbs={[
            { label: "HOME", href: "/" },
            { label: "TRADES WE SERVE", href: "/trades-we-serve" },
            { label: trade.name.toUpperCase() },
        ]}
    />

    <StatsBar stats={stats} />

    <TemplateGrid
        templates={tradeTemplates}
        tradeName={trade.name}
        showBrowseAllButton={true}
    />

    <ServiceFeatures
        tradeName={trade.name}
        tradeDescription={trade.hoverDescription}
    />

    <div class="px-6 pb-20 bg-white">
        <div class="max-w-7xl mx-auto">
            <CTA
                title="Ready to Get Started?"
                subtitle={`Take your ${trade.name.toLowerCase()} business online with a professional website. Contact us today for a free consultation.`}
                primaryCtaText="Get Free Quote"
                primaryCtaLink="/contact"
                secondaryCtaText="Browse Templates"
                secondaryCtaLink="/our-work"
            />
        </div>
    </div>
</BaseLayout>
