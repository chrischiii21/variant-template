---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero2 from "../../components/layout/Hero2.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const allTrades = await getCollection("trades");

    return allTrades.map((trade) => ({
        params: { slug: trade.data.slug },
        props: { trade: trade.data },
    }));
}

const { trade } = Astro.props;
---

<BaseLayout
    title={`${trade.name} | Your Company`}
    description={trade.hoverDescription}
>
    <Hero2
        title={trade.name}
        backgroundImage={trade.image}
        breadcrumbs={[
            { label: "HOME", href: "/" },
            { label: "TRADES WE SERVE", href: "/trades-we-serve" },
            { label: trade.name.toUpperCase() },
        ]}
    />

    <section class="py-16 px-6 max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
            <div>
                <h2
                    class="heading-h2 font-heading font-bold mb-6 text-[var(--color-primary)]"
                >
                    {trade.hoverTitle}
                </h2>
                <p class="text-base text-gray-600 mb-4 leading-relaxed">
                    {trade.hoverDescription}
                </p>
                <p class="text-base text-gray-600 mb-4 leading-relaxed">
                    Whether you need emergency repairs, routine maintenance, or
                    new installations, we're here to help. We pride ourselves on
                    delivering reliable, professional service every time.
                </p>
                <ul class="space-y-3">
                    <li class="flex items-start">
                        <span class="text-[var(--color-accent)] mr-3 font-bold"
                            >✓</span
                        >
                        <span class="text-base text-gray-600"
                            >Licensed and insured professionals</span
                        >
                    </li>
                    <li class="flex items-start">
                        <span class="text-[var(--color-accent)] mr-3 font-bold"
                            >✓</span
                        >
                        <span class="text-base text-gray-600"
                            >24/7 emergency services available</span
                        >
                    </li>
                    <li class="flex items-start">
                        <span class="text-[var(--color-accent)] mr-3 font-bold"
                            >✓</span
                        >
                        <span class="text-base text-gray-600"
                            >Competitive pricing and free estimates</span
                        >
                    </li>
                    <li class="flex items-start">
                        <span class="text-[var(--color-accent)] mr-3 font-bold"
                            >✓</span
                        >
                        <span class="text-base text-gray-600"
                            >Satisfaction guaranteed</span
                        >
                    </li>
                </ul>
            </div>
            <div class="relative h-96 overflow-hidden">
                <img
                    src={trade.image}
                    alt={trade.name}
                    class="w-full h-full object-cover"
                />
            </div>
        </div>
    </section>
</BaseLayout>
