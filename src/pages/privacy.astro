---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
import { getEntry } from "astro:content";
import { render } from "astro:content";

const page = await getEntry("pages", "privacy");
if (!page) throw new Error("Privacy page not found");
const { Content } = await render(page);
---

<BaseLayout
    title={`${page.data.title} | Your Company`}
    description={page.data.description}
>
    <Hero2
        title={page.data.title}
        breadcrumbs={[
            { label: "HOME", href: "/" },
            { label: page.data.title.toUpperCase() },
        ]}
    />

    <section class="py-16 px-6 max-w-4xl mx-auto">
        <div
            class="prose prose-lg max-w-none space-y-6 text-gray-600 prose-headings:text-primary prose-headings:font-heading prose-headings:font-bold prose-h2:text-2xl prose-h2:mb-4 prose-h2:mt-8 prose-ul:list-disc prose-ul:list-inside prose-ul:space-y-2 prose-p:leading-relaxed"
        >
            <Content />
        </div>
    </section>
</BaseLayout>
