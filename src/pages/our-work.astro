---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
---

<BaseLayout
    title="Our Work | Your Company"
    description="View our portfolio of completed projects"
>
    <Hero2
        title="Our Work"
        backgroundImage="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=1920&h=1080&fit=crop&q=80"
        breadcrumbs={[{ label: "HOME", href: "/" }, { label: "OUR WORK" }]}
    />

    <section class="py-16 px-6 max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                [1, 2, 3, 4, 5, 6].map((i) => (
                    <div class="bg-white shadow-lg overflow-hidden">
                        <div class="bg-gray-300 h-48 flex items-center justify-center">
                            <p class="text-gray-600">Project {i}</p>
                        </div>
                        <div class="p-6">
                            <h3 class="font-heading font-bold text-xl mb-2 text-[var(--color-primary)]">
                                Project Title {i}
                            </h3>
                            <p class="text-gray-600 text-base">
                                Description of the project and the services
                                provided.
                            </p>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>
</BaseLayout>
