---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
import Story from "../components/layout/Story.astro";
import Mission from "../components/layout/Mission.astro";
---

<BaseLayout
    title="About Us | Your Company"
    description="Learn about our company history and mission"
>
    <Hero2
        title="About Us"
        breadcrumbs={[{ label: "HOME", href: "/" }, { label: "ABOUT US" }]}
    />

    <Story 
        title="Our Story"
        paragraphs={[
            "Founded in 1982, we've been serving our community with professional and reliable services for over four decades.",
            "Our team of experienced professionals is dedicated to delivering exceptional results on every project, no matter the size or complexity.",
            "We believe in building long-term relationships with our clients based on trust, quality, and outstanding customer service."
        ]}
        image="https://images.unsplash.com/photo-1560472354-b33ff0c44a43?w=1920&h=1080&fit=crop&q=80"
        imageAlt="Professional team working together"
    />

    <Mission />
</BaseLayout>
