---
import About from "../components/layout/About.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/layout/Hero.astro";
import TrustBar from "../components/layout/TrustBar.astro";
import TemplateGallery from "../components/layout/TemplateGallery.astro";
import Features from "../components/layout/Features.astro";
import Reviews from "../components/layout/Reviews.astro";
import FAQ from "../components/layout/FAQ.astro";
import CTA from "../components/layout/CTA.astro";
---

<BaseLayout
	title="Premium Website Templates for Home Services & Trades | Your Company"
	description="Professional, conversion-optimized website templates built specifically for HVAC, plumbing, electrical, roofing, and landscaping businesses"
>
	<Hero
		backgroundImage="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1920&q=80"
		pretitle="PROFESSIONAL TEMPLATES FOR TRADES"
		title="GROW YOUR BUSINESS"
		subtitle="Premium Website Templates Built for Contractors & Home Service Pros"
		ctaText="BROWSE TEMPLATES"
		ctaLink="#templates"
	/>

	<TrustBar />

	<About />

	<TemplateGallery />

	<Features />

	<Reviews />

	<FAQ />

	<CTA />
</BaseLayout>
