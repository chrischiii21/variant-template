---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/layout/Hero.astro";
---

<BaseLayout
    title="What We Do | Your Company"
    description="Learn about our professional services and expertise"
>
    <Hero
        title="What We Do"
        subtitle="Comprehensive solutions for all your construction and trade needs"
        backgroundImage="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=1200&h=600&fit=crop"
    />

    <section class="py-16 px-6 max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="bg-white p-8 shadow-lg">
                <h3 class="font-heading font-bold text-2xl mb-4 text-[#304678]">
                    Professional Services
                </h3>
                <p class="text-gray-600">
                    We provide expert services across multiple trades and
                    industries with years of experience.
                </p>
            </div>
            <div class="bg-white p-8 shadow-lg">
                <h3 class="font-heading font-bold text-2xl mb-4 text-[#304678]">
                    Quality Assurance
                </h3>
                <p class="text-gray-600">
                    Every project is completed to the highest standards with
                    attention to detail and craftsmanship.
                </p>
            </div>
            <div class="bg-white p-8 shadow-lg">
                <h3 class="font-heading font-bold text-2xl mb-4 text-[#304678]">
                    Customer Focused
                </h3>
                <p class="text-gray-600">
                    Your satisfaction is our priority. We work closely with you
                    to exceed expectations.
                </p>
            </div>
        </div>
    </section>
</BaseLayout>
