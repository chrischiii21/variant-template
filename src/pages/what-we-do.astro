import TrustBar from "../components/layout/TrustBar.astro";
import Services from "../components/layout/Services.astro";
import CTA from "../components/layout/CTA.astro";
---

<BaseLayout
    title="What We Do | Your Company"
    description="Learn about our professional services and expertise"
>
    <Hero2
        title="What We Do"
        backgroundImage="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=1920&h=1080&fit=crop&q=80"
        breadcrumbs={[{ label: "HOME", href: "/" }, { label: "WHAT WE DO" }]}
    />
    <TrustBar />
    <Services />
    <CTA>
</BaseLayout>
