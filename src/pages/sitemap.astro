---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero2 from "../components/layout/Hero2.astro";
import { getCollection } from "astro:content";

// Get all trades for dynamic sitemap
const allTrades = await getCollection("trades");
const sortedTrades = allTrades.sort((a, b) => a.data.order - b.data.order);

const mainPages = [
    { label: "Home", href: "/" },
    { label: "What We Do", href: "/what-we-do" },
    { label: "Our Work", href: "/our-work" },
    { label: "About", href: "/about" },
    { label: "Contact", href: "/contact" },
];

const servicePages = [
    { label: "Trades We Serve", href: "/trades-we-serve" },
    { label: "Reviews", href: "/reviews" },
];

const legalPages = [
    { label: "Privacy Policy", href: "/privacy" },
    { label: "Terms of Service", href: "/terms" },
];
---

<BaseLayout title="Sitemap | Your Company" description="Website sitemap">
    <Hero2
        title="Sitemap"
        breadcrumbs={[{ label: "HOME", href: "/" }, { label: "SITEMAP" }]}
    />

    <section class="py-16 px-6 max-w-4xl mx-auto">
        <div class="space-y-8">
            <section>
                <h2
                    class="font-heading font-bold text-2xl md:text-3xl mb-4 text-primary"
                >
                    Main Pages
                </h2>
                <ul class="space-y-2">
                    {
                        mainPages.map((page) => (
                            <li>
                                <a
                                    href={page.href}
                                    class="text-primary hover:text-accent transition-colors text-lg"
                                >
                                    {page.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>

            <section>
                <h2
                    class="font-heading font-bold text-2xl md:text-3xl mb-4 text-primary"
                >
                    Services
                </h2>
                <ul class="space-y-2">
                    {
                        servicePages.map((page) => (
                            <li>
                                <a
                                    href={page.href}
                                    class="text-primary hover:text-accent transition-colors text-lg"
                                >
                                    {page.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>

            <section>
                <h2
                    class="font-heading font-bold text-2xl md:text-3xl mb-4 text-primary"
                >
                    Trade Categories
                </h2>
                <ul class="space-y-2">
                    {
                        sortedTrades.map((trade) => (
                            <li>
                                <a
                                    href={`/trades-we-serve/${trade.data.slug}`}
                                    class="text-primary hover:text-accent transition-colors text-lg"
                                >
                                    {trade.data.name}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>

            <section>
                <h2
                    class="font-heading font-bold text-2xl md:text-3xl mb-4 text-primary"
                >
                    Legal
                </h2>
                <ul class="space-y-2">
                    {
                        legalPages.map((page) => (
                            <li>
                                <a
                                    href={page.href}
                                    class="text-primary hover:text-accent transition-colors text-lg"
                                >
                                    {page.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </section>
        </div>
    </section>
</BaseLayout>
