---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sitemap | Your Company" description="Website sitemap">
    <section class="py-16 px-6 max-w-4xl mx-auto">
        <h1 class="font-heading font-bold text-5xl mb-8 text-[#304678]">
            Sitemap
        </h1>

        <div class="space-y-8">
            <section>
                <h2 class="font-heading font-bold text-4xl mb-4 text-[#304678]">
                    Main Pages
                </h2>
                <ul class="space-y-2">
                    <li>
                        <a href="/" class="text-[#304678] hover:text-[#f59f0a]"
                            >Home</a
                        >
                    </li>
                    <li>
                        <a
                            href="/what-we-do"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >What We Do</a
                        >
                    </li>
                    <li>
                        <a
                            href="/our-work"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Our Work</a
                        >
                    </li>
                    <li>
                        <a
                            href="/about"
                            class="text-[#304678] hover:text-[#f59f0a]">About</a
                        >
                    </li>
                    <li>
                        <a
                            href="/contact"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Contact</a
                        >
                    </li>
                </ul>
            </section>

            <section>
                <h2 class="font-heading font-bold text-4xl mb-4 text-[#304678]">
                    Services
                </h2>
                <ul class="space-y-2">
                    <li>
                        <a
                            href="/trades-we-serve"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Trades We Serve</a
                        >
                    </li>
                    <li>
                        <a
                            href="/reviews"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Reviews</a
                        >
                    </li>
                </ul>
            </section>

            <section>
                <h2 class="font-heading font-bold text-4xl mb-4 text-[#304678]">
                    Legal
                </h2>
                <ul class="space-y-2">
                    <li>
                        <a
                            href="/privacy"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Privacy Policy</a
                        >
                    </li>
                    <li>
                        <a
                            href="/terms"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Terms of Service</a
                        >
                    </li>
                </ul>
            </section>

            <section>
                <h2 class="font-heading font-bold text-4xl mb-4 text-[#304678]">
                    Trade Categories
                </h2>
                <ul class="space-y-2">
                    <li>
                        <a
                            href="/trades-we-serve/plumbing"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Plumbing</a
                        >
                    </li>
                    <li>
                        <a
                            href="/trades-we-serve/electrical"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Electrical</a
                        >
                    </li>
                    <li>
                        <a
                            href="/trades-we-serve/hvac"
                            class="text-[#304678] hover:text-[#f59f0a]">HVAC</a
                        >
                    </li>
                    <li>
                        <a
                            href="/trades-we-serve/carpentry"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Carpentry</a
                        >
                    </li>
                    <li>
                        <a
                            href="/trades-we-serve/roofing"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Roofing</a
                        >
                    </li>
                    <li>
                        <a
                            href="/trades-we-serve/masonry"
                            class="text-[#304678] hover:text-[#f59f0a]"
                            >Masonry</a
                        >
                    </li>
                </ul>
            </section>
        </div>
    </section>
</BaseLayout>
